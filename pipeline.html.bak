        <input type="date" id="new-nextActionDate">
      </div>
      <div class="modal-full d-field">
        <label>Notes</label>
        <textarea id="new-notes" rows="3" placeholder="How you found them, what they said, key context..."></textarea>
      </div>
    </div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeAddModal()">Cancel</button>
      <button class="btn btn-primary" onclick="saveNewProspect()">&#10003; Add Prospect</button>
    </div>
  </div>
</div>

<script>
// ── ACCESS CONTROL + SETTINGS (shared with Portfolio dashboard) ──
const VALID_CODES = ['DEKA-NE-2026-ANTHONY','DEKA-SE-2026','DEKA-MW-2026','DEKA-SW-2026','DEKA-W-2026'];
const DEFAULT_SETTINGS = {
  firstName:'Anthony', fullName:'Anthony Passamonte', region:'Northeast',
  regionFilter:'North East', calendarLink:'https://calendar.app.google/KtfQhJTg9wmrJhvs6',
  emailSignature:'Anthony\nDEKA Fitness — Northeast Account Manager',
  territoryDesc:'Maine to Virginia', states:'CT,MA,NJ,NY,PA,VA,NH,RI,VT,DE,ME,MD'
};
window.SETTINGS = JSON.parse(localStorage.getItem('deka_settings')||'null') || {...DEFAULT_SETTINGS};
function _s(key, fallback) { return (window.SETTINGS && window.SETTINGS[key]) || fallback || ''; }

function _checkAccess() {
  if (!window.ACCESS_GATE_ENABLED) return true;
  const stored = localStorage.getItem('deka_access');
  if (stored && VALID_CODES.includes(stored)) return true;
  return false;
}
window.ACCESS_GATE_ENABLED = false;
function _submitAccessPL() {
  const input = document.getElementById('access-code-input');
  const err = document.getElementById('access-error');
  const code = (input.value||'').trim().toUpperCase();
  if (VALID_CODES.includes(code)) {
    localStorage.setItem('deka_access', code);
    document.getElementById('access-gate').style.display='none';
    document.body.classList.remove('locked');
    init();
  } else {
    err.style.display='block';
    input.style.borderColor='var(--accent,#e74c3c)';
    input.classList.add('shake');
    setTimeout(()=>input.classList.remove('shake'),500);
  }
}

// ── DATA ──
const PIPELINE_KEY = 'deka_pipeline';
const GS_CONFIG_KEY = 'deka_gs_config';
const GS_SECRET = 'deka-nam-2026';
const NE_STATES = _s('states','CT,MA,NY,NJ,PA,VA,MD,DC,RI,ME,NH,VT,DE').split(',').map(s=>s.trim());
const STAGES = ['lead','contacted','proposal','discovery','negotiating','signed','nurture','lost'];
const ACTIVE_STAGES = ['lead','contacted','proposal','discovery','negotiating'];
const SECONDARY_STAGES = ['signed','nurture','lost'];
const STAGE_LABELS = {lead:'Lead',contacted:'Contacted',proposal:'Proposal (Followed Up 2-3x)',discovery:'Discovery Call',negotiating:'Negotiating',signed:'Signed',nurture:'Follow Up Later',lost:'Closed Lost'};
const STAGE_ICONS = {lead:'🎯',contacted:'📞',proposal:'📋',discovery:'📅',negotiating:'✍️',signed:'✅',nurture:'⏰',lost:'🚫'};
const STAGE_ORDER = {lead:1,contacted:2,proposal:3,discovery:4,negotiating:5,signed:6,nurture:7,lost:0};

let pipelineData = {prospects:[], goals:{newAffiliates2026:8, targetStates:['NH','VT','DE']}};
let currentDetailId = null;
let selectedIds = new Set();
let listSortCol = 'priority';
let listSortDir = 'asc';

function loadPipeline() {
  const raw = localStorage.getItem(PIPELINE_KEY);
  if (raw) { try { pipelineData = JSON.parse(raw); } catch(e) {} }
  if (!pipelineData.prospects) pipelineData.prospects = [];
  if (!pipelineData.goals) pipelineData.goals = {newAffiliates2026:8, targetStates:[]};
}

function savePipeline() {
  localStorage.setItem(PIPELINE_KEY, JSON.stringify(pipelineData));
}

function genId() {
  return 'p_' + Date.now().toString(36) + Math.random().toString(36).slice(2,6);
}

// ── INIT ──
async function init() {
  // Supabase Auth check (TEMP BYPASS for local testing)
  if (false && typeof dekaAuthCheck === 'function') {
    const authResult = await dekaAuthCheck();
    if (authResult === false) return;
    if (authResult === 'needs_setup') return;
  }
  loadPipeline();
  populateStateFilter();
  showView('board', document.querySelector('.nav-tab'));
  updateHeaderSub();

  // Deep-link: auto-open onboarding modal if ?onboard=gymName is in the URL
  const params = new URLSearchParams(window.location.search);
  const onboardName = params.get('onboard');
  if (onboardName) {
    const match = pipelineData.prospects.find(p =>
      p.gymName && p.gymName.toLowerCase().replace(/[^a-z0-9]/g,'') === onboardName.toLowerCase().replace(/[^a-z0-9]/g,'')
    );
    if (match) {
      // Ensure onboarding tasks exist
      if (!match.onboardingTasks || match.onboardingTasks.length === 0) {
        match.onboardingTasks = JSON.parse(JSON.stringify(DEFAULT_ONBOARDING_TASKS));
        match.onboardingStart = new Date().toISOString().slice(0,10);
        savePipeline();
      }
      setTimeout(() => openOnboardingModal(match.id), 300);
    }
  }
}

function updateHeaderSub() {
  const active = pipelineData.prospects.filter(p => p.stage !== 'lost' && p.stage !== 'signed').length;
  const hot = pipelineData.prospects.filter(p => p.priority === 'hot' && p.stage !== 'lost').length;
  const signed = pipelineData.prospects.filter(p => p.stage === 'signed').length;
  document.getElementById('hdr-sub').textContent =
    `${_s('fullName','Anthony Passamonte')} \u2022 ${_s('region','Northeast')} \u2022 ${active} Active \u2022 ${hot} Hot \u2022 ${signed} Signed`;
}

function populateStateFilter() {
  const states = [...new Set(pipelineData.prospects.map(p => p.state).filter(Boolean))].sort();
  const sel = document.getElementById('flt-state');
  sel.innerHTML = '<option value="">All States</option>';
  states.forEach(s => { const o = document.createElement('option'); o.value = o.textContent = s; sel.appendChild(o); });
}

// ── VIEWS ──
let currentView = 'board';
function showView(id, btn) {
  ['board','list','analytics','import'].forEach(v => {
    document.getElementById('view-'+v).style.display = v===id ? 'block' : 'none';
  });
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  if (btn) btn.classList.add('active');
  document.getElementById('board-toolbar').style.display = (id==='board'||id==='list') ? 'flex' : 'none';
  currentView = id;
  if (id==='board') renderBoard();
  else if (id==='list') renderList();
  else if (id==='analytics') renderAnalytics();
  else if (id==='import') initSheet2Config();
}

// ── Bulk selection ──────────────────────────────────────────────────────────
function toggleSelect(id) {
  if (selectedIds.has(id)) selectedIds.delete(id);
  else selectedIds.add(id);
  const card = document.getElementById('pcard-' + id);
  if (card) card.classList.toggle('selected', selectedIds.has(id));
  _syncColCheckbox(id);
  updateBulkBar();
}

function toggleSelectAll(stage, cb) {
  const stageProspects = pipelineData.prospects.filter(p => p.stage === stage);
  stageProspects.forEach(p => {
    if (cb.checked) selectedIds.add(p.id);
    else selectedIds.delete(p.id);
    const card = document.getElementById('pcard-' + p.id);
    if (card) card.classList.toggle('selected', cb.checked);
  });
  updateBulkBar();
}

function _syncColCheckbox(id) {
  const p = pipelineData.prospects.find(x => x.id === id);
  if (!p) return;
  const cb = document.getElementById('colcheck-' + p.stage);
  if (!cb) return;
  const stageProspects = pipelineData.prospects.filter(x => x.stage === p.stage);
  cb.checked = stageProspects.length > 0 && stageProspects.every(x => selectedIds.has(x.id));
  cb.indeterminate = !cb.checked && stageProspects.some(x => selectedIds.has(x.id));
}

function updateBulkBar() {
  const bar = document.getElementById('bulk-bar');
  const cnt = document.getElementById('bulk-count');
  if (!bar || !cnt) return;
  bar.classList.toggle('hidden', selectedIds.size === 0);
  cnt.textContent = selectedIds.size + ' selected';
}

function clearSelection() {
  selectedIds.forEach(id => {
    const card = document.getElementById('pcard-' + id);
    if (card) card.classList.remove('selected');
  });
  selectedIds.clear();
  document.querySelectorAll('.col-check-all').forEach(cb => { cb.checked = false; cb.indeterminate = false; });
  updateBulkBar();
}

function batchEmail() {
  if (selectedIds.size === 0) return;

  const selected = [...selectedIds].map(id => pipelineData.prospects.find(x => x.id === id)).filter(Boolean);
  const withEmail = selected.filter(p => !!(p.email || '').trim());
  const noEmail   = selected.filter(p =>  !(p.email || '').trim());

  if (withEmail.length === 0) {
    alert(`None of the ${selected.length} selected prospect${selected.length !== 1 ? 's have' : ' has'} an email on file.\n\nOpen each card \u2192 Contact Info \u2192 add their email, then try again.`);
    return;
  }

  // Open Gmail FIRST — before any DOM work — so Chrome's user gesture is still fresh
  _sendGmailForProspects(withEmail);

  // THEN log + stage updates
  const today = new Date().toISOString().slice(0, 10);
  const followUp = new Date(); followUp.setDate(followUp.getDate() + 3);
  const followUpStr = followUp.toISOString().slice(0, 10);
  withEmail.forEach(p => {
    if (!p.activities) p.activities = [];
    p.activities.unshift({ date: today, type: 'email', notes: 'Batch email sent \u2014 DEKA Affiliate Partnership outreach' });
    p.lastActivity = today;
    p.nextAction = 'Follow up';
    p.nextActionDate = followUpStr;
    if (p.stage !== 'contacted') {
      p.stage = 'contacted';
      p.activities.unshift({ date: today, type: 'stage', notes: `Moved to ${STAGE_LABELS['contacted']}` });
    }
  });

  savePipeline();
  clearSelection();
  renderBoard();
  updateHeaderSub();

  const skippedMsg = noEmail.length ? ` \u00b7 ${noEmail.length} skipped (no email)` : '';
  showToast(`\u2709 Gmail opened \u2014 ${withEmail.length} recipient${withEmail.length !== 1 ? 's' : ''} in ${withEmail.length > 1 ? 'BCC' : 'TO'}${skippedMsg}`);
}

// ── FILTERS ──
// Open territory states (0-1 affiliates) — higher prospect priority
const OPEN_TERRITORY = ['NH','VT','ME','DE'];

function prospectScore(p) {
  let score = 0;
  score += {hot:30, warm:15, cold:5}[p.priority] || 5;
  score += {lead:5,contacted:10,nurture:3,discovery:15,proposal:20,negotiating:25,signed:0,lost:0}[p.stage] || 0;
  if (p.email) score += 8;
  if (p.phone) score += 5;
  if (p.estimatedRevenue) score += 5;
  const daysSince = p.lastActivity ? Math.floor((Date.now()-new Date(p.lastActivity+'T12:00:00'))/86400000) : 999;
  if (daysSince <= 7) score += 10;
  else if (daysSince <= 14) score += 5;
  if (OPEN_TERRITORY.includes(p.state)) score += 10;
  const gt = (p.gymType||'').toLowerCase();
  if (gt.includes('crossfit') || gt.includes('functional') || gt.includes('hyrox')) score += 10;
  if (p.notes && p.notes.length > 20) score += 3;
  const today = new Date(); today.setHours(0,0,0,0);
  if (p.nextActionDate && new Date(p.nextActionDate+'T12:00:00') < today) score -= 5;
  return score;
}

function getSorted(list) {
  const sortCol = document.getElementById('flt-sort')?.value || 'score';
  return [...list].sort((a,b) => {
    if (sortCol === 'score') return prospectScore(b) - prospectScore(a);
    if (sortCol === 'priority') return ({hot:0,warm:1,cold:2}[a.priority]||1) - ({hot:0,warm:1,cold:2}[b.priority]||1);
    if (sortCol === 'stage') return (STAGE_ORDER[b.stage]||0) - (STAGE_ORDER[a.stage]||0);
    if (sortCol === 'lastActivity') return (b.lastActivity||'').localeCompare(a.lastActivity||'');
    return (a.gymName||'').localeCompare(b.gymName||'');
  });
}

function getFiltered(includeAll) {
  const q = document.getElementById('search-input').value.toLowerCase();
  const pri = document.getElementById('flt-priority').value;
  const src = document.getElementById('flt-source').value;
  const st = document.getElementById('flt-state').value;
  return pipelineData.prospects.filter(p => {
    if (!includeAll && (p.stage === 'lost' || p.stage === 'signed' || p.stage === 'nurture')) return false;
    if (pri && p.priority !== pri) return false;
    if (src && p.source !== src) return false;
    if (st && p.state !== st) return false;
    if (q) {
      const hay = [p.gymName, p.ownerName, p.city, p.state, p.email, p.source, p.notes].join(' ').toLowerCase();
      if (!hay.includes(q)) return false;
    }
    return true;
  });
}

function applyFilters() {
  if (currentView === 'board') renderBoard();
  else if (currentView === 'list') renderList();
}

// ── KANBAN BOARD ──
function renderBoard() {
  const filtered = getFiltered();
  const allProspects = getFiltered(true);
  const activeCount = filtered.length;
  const signedCount = allProspects.filter(p=>p.stage==='signed').length;
  const nurtureCount = allProspects.filter(p=>p.stage==='nurture').length;
  const lostCount = allProspects.filter(p=>p.stage==='lost').length;
  document.getElementById('prospect-count').textContent = `${activeCount} active of ${pipelineData.prospects.length} prospects`;

  const byStage = {};
  STAGES.forEach(s => byStage[s] = []);
  allProspects.forEach(p => { if (byStage[p.stage]) byStage[p.stage].push(p); });
  // Also add filtered-only active prospects
  filtered.forEach(p => {
    if (ACTIVE_STAGES.includes(p.stage) && !byStage[p.stage].includes(p)) byStage[p.stage].push(p);
  });

  const board = document.getElementById('kanban-board');

  // Sort cards within each column: Hot first, then Warm, then Cold
  // Within each priority: soonest next-action-date first, overdue at very top, no date last
  const _priWeight = {hot:1, warm:2, cold:3};
  const _sortCards = (cards) => {
    const now = Date.now();
    return [...cards].sort((a,b) => {
      const pa = _priWeight[a.priority] || 3;
      const pb = _priWeight[b.priority] || 3;
      if (pa !== pb) return pa - pb;
      // Same priority: sort by next action date (soonest first, no date last)
      const da = a.nextActionDate ? new Date(a.nextActionDate+'T12:00:00').getTime() : Infinity;
      const db = b.nextActionDate ? new Date(b.nextActionDate+'T12:00:00').getTime() : Infinity;
      return da - db;
    });
  };

  // Build cards HTML with priority group separators
  const _buildColumnCards = (cards) => {
    if (cards.length === 0) return `<div style="text-align:center;padding:20px 8px;color:var(--text-dim);font-size:11px">Drop here</div>`;
    const sorted = _sortCards(cards);
    let html = '';
    let lastPri = '';
    sorted.forEach(p => {
      const pri = p.priority || 'cold';
      if (pri !== lastPri && lastPri !== '') {
        // Insert separator between priority groups
        const priLabels = {hot:'\uD83D\uDD25 HOT',warm:'\uD83D\uDE0A WARM',cold:'\u2744\uFE0F COLD'};
        html += `<div style="text-align:center;padding:4px 0;margin:4px 0"><span style="font-size:9px;letter-spacing:1px;color:var(--text-dim);opacity:0.5">\u2500\u2500 ${priLabels[pri]||pri.toUpperCase()} \u2500\u2500</span></div>`;
      }
      lastPri = pri;
      html += cardHTML(p);
    });
    return html;
  };

  // Active pipeline columns
  const activeHTML = ACTIVE_STAGES.map(stage => {
    const cards = byStage[stage];
    return `<div class="board-col col-${stage}" id="col-${stage}" ondragover="onDragOver(event,'${stage}')" ondrop="onDrop(event,'${stage}')" ondragleave="onDragLeave(event)">
      <div class="col-header">${STAGE_ICONS[stage]} ${STAGE_LABELS[stage]} <span style="opacity:0.6">${cards.length}</span><label class="col-check-wrap" onclick="event.stopPropagation()" title="Select all in this column"><input type="checkbox" class="col-check-all" id="colcheck-${stage}" onchange="toggleSelectAll('${stage}',this)"><span>All</span></label></div>
      <div class="col-body" id="colbody-${stage}">
        ${_buildColumnCards(cards)}
      </div>
    </div>`;
  }).join('');

  // Follow Up Later alert check
  const today = new Date(); today.setHours(0,0,0,0);
  const nurtureOverdue = byStage['nurture'].filter(p => p.nextActionDate && new Date(p.nextActionDate+'T12:00:00') < today);
  const nurtureAlertHTML = nurtureOverdue.length > 0
    ? `<span style="background:var(--accent);color:#fff;font-size:10px;font-weight:700;padding:2px 8px;border-radius:10px;margin-left:8px;animation:pulse 2s infinite">${nurtureOverdue.length} overdue</span>`
    : '';

  // Secondary sections
  const secondaryHTML = `
    <div style="margin-top:20px;display:flex;flex-direction:column;gap:10px" id="secondary-stages">
      ${_renderSecondarySection('signed', byStage['signed'], 'rgba(74,222,128,0.15)', 'var(--green)', '')}
      ${_renderSecondarySection('nurture', byStage['nurture'], 'rgba(13,148,136,0.15)', '#0d9488', nurtureAlertHTML)}
      ${_renderSecondarySection('lost', byStage['lost'], 'rgba(55,65,81,0.3)', 'var(--text-dim)', '')}
    </div>`;

  board.innerHTML = `<div class="board" style="display:flex;gap:14px;min-width:max-content;align-items:flex-start">${activeHTML}</div>${secondaryHTML}`;
  renderActionQueue();
}

let _aqCollapsed = false;
let _aqSelectedIds = new Set();
let _aqSort = 'due';      // 'due' | 'alpha' | 'state' | 'stage' | 'priority'
let _aqFilterState = '';   // '' = all, or specific state abbreviation

function _sendGmailForProspects(prospects) {
  const emails = prospects.map(p => (p.email || '').trim()).filter(Boolean);
  if (emails.length === 0) return false;
  const subject = 'DEKA Fitness \u2014 Affiliate Partnership Opportunity';
  const body =
`Hi,

I\u2019m reaching out about an exciting opportunity to bring DEKA Fitness events to your facility.

DEKA events are structured, standardized functional fitness competitions that drive member engagement, foot traffic, and new revenue for host gyms \u2014 with full support from our team every step of the way.

I\u2019d love to set up a quick 15-minute call to share more. Would you be open to connecting this week?

Looking forward to hearing from you,

${_s('firstName','Anthony')}
DEKA Fitness \u2014 ${_s('region','Northeast')} Account Manager`;

  const to  = emails.length === 1 ? emails[0] : '';
  const bcc = emails.length  > 1  ? emails.join(',') : '';
  let url = `https://mail.google.com/mail/?view=cm&su=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  if (to)  url += `&to=${encodeURIComponent(to)}`;
  if (bcc) url += `&bcc=${encodeURIComponent(bcc)}`;
  openGmail(url);
  return true;
}
function toggleActionQueue() {
  _aqCollapsed = !_aqCollapsed;
  const body = document.getElementById('action-queue-body');
  const icon = document.getElementById('aq-toggle-icon');
  if (body) body.style.display = _aqCollapsed ? 'none' : '';
  if (icon) icon.textContent = _aqCollapsed ? '▼' : '▲';
}

function renderActionQueue() {
  const body   = document.getElementById('action-queue-body');
  const badge  = document.getElementById('aq-overdue-badge');
  const sumTxt = document.getElementById('aq-summary-text');
  if (!body) return;

  const today = new Date(); today.setHours(0,0,0,0);
  const in7   = new Date(today); in7.setDate(in7.getDate() + 7);
  const todayStr = today.toISOString().slice(0,10);

  const prospects = pipelineData.prospects.filter(p =>
    p.stage !== 'lost' && (p.nextAction || p.nextActionDate)
  );

  const overdue = [], dueToday = [], thisWeek = [], upcoming = [];
  prospects.forEach(p => {
    if (!p.nextActionDate) { upcoming.push(p); return; }
    const d = new Date(p.nextActionDate + 'T12:00:00');
    if (d < today)                  overdue.push(p);
    else if (p.nextActionDate === todayStr) dueToday.push(p);
    else if (d <= in7)              thisWeek.push(p);
    else                            upcoming.push(p);
  });

  // Overdue badge
  if (badge) {
    badge.innerHTML = overdue.length > 0
      ? `<span style="background:var(--accent);color:#fff;font-size:10px;font-weight:700;padding:2px 8px;border-radius:10px;animation:pulse 2s infinite">${overdue.length} overdue</span>`
      : '';
  }
  if (sumTxt) {
    const parts = [];
    if (dueToday.length) parts.push(`${dueToday.length} today`);
    if (thisWeek.length) parts.push(`${thisWeek.length} this week`);
    if (upcoming.length) parts.push(`${upcoming.length} upcoming`);
    sumTxt.textContent = parts.length ? '· ' + parts.join(' · ') : (prospects.length === 0 ? '· No actions set' : '');
  }

  if (_aqCollapsed || prospects.length === 0) {
    body.innerHTML = prospects.length === 0
      ? `<div style="padding:12px 14px;font-size:11px;color:var(--text-dim)">No next actions set on any active prospects. Open a prospect card and fill in Next Action + Due Date to track follow-ups here.</div>`
      : '';
    if (_aqCollapsed) body.style.display = 'none';
    return;
  }

  // ── Filter by state ──
  const allProspects = [...overdue, ...dueToday, ...thisWeek, ...upcoming];
  const states = [...new Set(allProspects.map(p=>p.state).filter(Boolean))].sort();
  if (_aqFilterState) {
    overdue.splice(0, overdue.length, ...overdue.filter(p=>p.state===_aqFilterState));
    dueToday.splice(0, dueToday.length, ...dueToday.filter(p=>p.state===_aqFilterState));
    thisWeek.splice(0, thisWeek.length, ...thisWeek.filter(p=>p.state===_aqFilterState));
    upcoming.splice(0, upcoming.length, ...upcoming.filter(p=>p.state===_aqFilterState));
  }

  // ── Sort within each group ──
  const sortFn = (a,b) => {
    if (_aqSort==='alpha') return (a.gymName||'').localeCompare(b.gymName||'');
    if (_aqSort==='state') return (a.state||'').localeCompare(b.state||'') || (a.gymName||'').localeCompare(b.gymName||'');
    if (_aqSort==='stage') return (a.stage||'').localeCompare(b.stage||'') || (a.gymName||'').localeCompare(b.gymName||'');
    if (_aqSort==='priority') { const w={hot:0,warm:1,cold:2}; return (w[a.priority]??3)-(w[b.priority]??3) || (a.gymName||'').localeCompare(b.gymName||''); }
    // default 'due' — sort by nextActionDate ascending
    return (a.nextActionDate||'9999').localeCompare(b.nextActionDate||'9999');
  };
  overdue.sort(sortFn); dueToday.sort(sortFn); thisWeek.sort(sortFn); upcoming.sort(sortFn);

  // ── Filter / Sort toolbar ──
  const sortBtn = (label, key) => `<button onclick="event.stopPropagation();_aqSetSort('${key}')" style="background:${_aqSort===key?'var(--blue)':'none'};border:1px solid ${_aqSort===key?'var(--blue)':'var(--border)'};color:${_aqSort===key?'#fff':'var(--text-dim)'};border-radius:5px;padding:2px 8px;font-size:10px;cursor:pointer;font-weight:600">${label}</button>`;
  const stateOpts = states.map(s=>`<option value="${s}" ${_aqFilterState===s?'selected':''}>${s}</option>`).join('');
  const filterBar = `<div onclick="event.stopPropagation()" style="display:flex;align-items:center;gap:8px;padding:8px 14px;background:var(--card);border-bottom:1px solid var(--border);flex-wrap:wrap">
    <span style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-dim)">Sort:</span>
    ${sortBtn('Due Date','due')}${sortBtn('A–Z','alpha')}${sortBtn('State','state')}${sortBtn('Stage','stage')}${sortBtn('Priority','priority')}
    <span style="width:1px;height:16px;background:var(--border);margin:0 4px"></span>
    <span style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-dim)">Filter:</span>
    <select onchange="event.stopPropagation();_aqSetFilter(this.value)" style="background:var(--card2);border:1px solid var(--border);color:var(--text);border-radius:5px;padding:2px 6px;font-size:10px;cursor:pointer">
      <option value="">All States</option>${stateOpts}
    </select>
    ${_aqFilterState?`<button onclick="event.stopPropagation();_aqSetFilter('')" style="background:none;border:1px solid var(--accent);color:var(--accent);border-radius:5px;padding:2px 8px;font-size:10px;cursor:pointer">✕ Clear</button>`:''}
  </div>`;

  const priIcon = {hot:'🔥',warm:'😊',cold:'❄️'};
  const stageLabel = s => STAGE_LABELS[s] || s;

  const rowHTML = (p, color, label) => {
    const dateStr = p.nextActionDate || '';
    const checked = _aqSelectedIds.has(p.id) ? 'checked' : '';
    return `<div id="aqrow-${p.id}" style="display:flex;align-items:center;gap:10px;padding:8px 14px;border-bottom:1px solid var(--border);transition:background 0.15s" onmouseover="this.style.background='var(--card)'" onmouseout="this.style.background=''">
      <input type="checkbox" ${checked} onclick="event.stopPropagation();_aqToggle('${p.id}')" style="flex-shrink:0;accent-color:var(--blue);width:14px;height:14px;cursor:pointer">
      <span style="font-size:11px;flex-shrink:0">${priIcon[p.priority]||'•'}</span>
      <span onclick="openDetail('${p.id}')" style="font-size:12px;font-weight:600;color:var(--text);min-width:160px;flex-shrink:0;cursor:pointer">${esc(p.gymName)}</span>
      <span style="font-size:10px;color:var(--text-dim);flex-shrink:0;min-width:30px">${p.state||''}</span>
      <span onclick="openDetail('${p.id}')" style="font-size:10px;color:var(--text-dim);flex-shrink:0;min-width:90px;cursor:pointer">${stageLabel(p.stage)}</span>
      <span onclick="openDetail('${p.id}')" style="font-size:11px;color:var(--text-mid);flex:1;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;cursor:pointer">${esc(p.nextAction||'—')}</span>
      <span onclick="openDetail('${p.id}')" style="font-size:11px;font-weight:600;color:${color};flex-shrink:0;min-width:80px;text-align:right;cursor:pointer">${dateStr ? label + ' ' + dateStr : 'No date'}</span>
      <span onclick="openDetail('${p.id}')" style="font-size:10px;color:var(--text-dim);flex-shrink:0;cursor:pointer">Open →</span>
    </div>`;
  };

  const sectionHeader = (label, color, count) =>
    `<div style="padding:5px 14px;background:${color}18;border-bottom:1px solid var(--border)">
      <span style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:${color}">${label} (${count})</span>
    </div>`;

  let html = '';
  if (overdue.length)   { html += sectionHeader('Overdue', 'var(--accent)', overdue.length);   overdue.forEach(p =>   html += rowHTML(p, 'var(--accent)', '')); }
  if (dueToday.length)  { html += sectionHeader('Due Today', 'var(--yellow)', dueToday.length); dueToday.forEach(p =>  html += rowHTML(p, 'var(--yellow)', 'Today')); }
  if (thisWeek.length)  { html += sectionHeader('This Week', 'var(--blue)', thisWeek.length);   thisWeek.forEach(p =>  html += rowHTML(p, 'var(--blue)', '')); }
  if (upcoming.length)  { html += sectionHeader('Upcoming', 'var(--text-dim)', upcoming.length); upcoming.forEach(p => html += rowHTML(p, 'var(--text-dim)', '')); }

  const filteredTotal = overdue.length + dueToday.length + thisWeek.length + upcoming.length;
  const filterNote = _aqFilterState ? `<div style="padding:6px 14px;font-size:10px;color:var(--text-dim);border-bottom:1px solid var(--border)">Showing ${filteredTotal} of ${allProspects.length} prospects in ${_aqFilterState}</div>` : '';
  const rowsHtml = html || `<div style="padding:12px 14px;font-size:11px;color:var(--text-dim)">${_aqFilterState ? 'No prospects in ' + _aqFilterState + ' with pending actions.' : 'All clear — no overdue or upcoming actions.'}</div>`;
  const aqActionBar = _aqSelectedIds.size > 0
    ? `<div style="display:flex;align-items:center;gap:8px;padding:8px 14px;background:var(--card2);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:2;flex-wrap:wrap">
        <span style="font-size:11px;font-weight:600;color:var(--text)">${_aqSelectedIds.size} selected</span>
        <button class="btn btn-blue btn-sm" onclick="aqBatchEmail()" style="font-size:11px">&#9993; Send Batch Email</button>
        <button class="btn btn-ghost btn-sm" onclick="aqBatchFollowUp()" style="font-size:11px;border-color:var(--yellow);color:var(--yellow)">📅 Follow-up 1 Week</button>
        <button class="btn btn-ghost btn-sm" onclick="aqBatchAdvanceStage()" style="font-size:11px;border-color:var(--green);color:var(--green)">➡ Advance Stage</button>
        <button class="btn btn-ghost btn-sm" onclick="_aqClear()" style="font-size:11px">&#10005; Clear</button>
      </div>`
    : '';
  body.innerHTML = filterBar + aqActionBar + filterNote + rowsHtml;
  body.style.display = '';
}

function _aqToggle(id) {
  if (_aqSelectedIds.has(id)) _aqSelectedIds.delete(id);
  else _aqSelectedIds.add(id);
  renderActionQueue();
}
function _aqClear() {
  _aqSelectedIds.clear();
  renderActionQueue();
}
function _aqSetSort(key) {
  _aqSort = key;
  renderActionQueue();
}
function _aqSetFilter(state) {
  _aqFilterState = state;
  renderActionQueue();
}

function aqBatchFollowUp() {
  if (_aqSelectedIds.size === 0) return;
  const today = new Date().toISOString().slice(0,10);
  const fu = new Date(); fu.setDate(fu.getDate()+7);
  const fuStr = fu.toISOString().slice(0,10);
  const count = _aqSelectedIds.size;
  [..._aqSelectedIds].forEach(id => {
    const p = pipelineData.prospects.find(x => x.id === id);
    if (!p) return;
    if (!p.activities) p.activities = [];
    p.activities.unshift({date:today, type:'note', notes:'Follow-up scheduled (batch action)'});
    p.lastActivity = today;
    p.nextAction = 'Follow up';
    p.nextActionDate = fuStr;
  });
  savePipeline();
  _aqClear();
  renderBoard();
  updateHeaderSub();
  showToast(`📅 ${count} prospect${count!==1?'s':''} — follow-up set for ${fuStr}`);
}

function aqBatchAdvanceStage() {
  if (_aqSelectedIds.size === 0) return;
  const stageSeq = ['lead','contacted','proposal','discovery','negotiating','signed'];
  const today = new Date().toISOString().slice(0,10);
  let moved = 0;
  [..._aqSelectedIds].forEach(id => {
    const p = pipelineData.prospects.find(x => x.id === id);
    if (!p) return;
    const idx = stageSeq.indexOf(p.stage);
    if (idx < 0 || idx >= stageSeq.length - 1) return; // skip if already signed or not in sequence
    const newStage = stageSeq[idx + 1];
    if (!p.activities) p.activities = [];
    p.activities.unshift({date:today, type:'stage', notes:`Moved to ${STAGE_LABELS[newStage]||newStage} (batch action)`});
    p.stage = newStage;
    p.lastActivity = today;
    moved++;
  });
  savePipeline();
  _aqClear();
  renderBoard();
  updateHeaderSub();
  showToast(`➡ ${moved} prospect${moved!==1?'s':''} advanced to next stage`);
}

function aqBatchEmail() {
  if (_aqSelectedIds.size === 0) return;
  const prospects = [..._aqSelectedIds].map(id => pipelineData.prospects.find(x => x.id === id)).filter(Boolean);
  const withEmail = prospects.filter(p => !!(p.email || '').trim());

  if (withEmail.length === 0) {
    alert('None of the selected prospects have an email on file.\n\nOpen each card \u2192 Contact Info \u2192 add their email.');
    return;
  }

  // Open Gmail FIRST
  _sendGmailForProspects(withEmail);

  // Then log activity
  const today = new Date().toISOString().slice(0,10);
  const followUp = new Date(); followUp.setDate(followUp.getDate()+7);
  const followUpStr = followUp.toISOString().slice(0,10);
  withEmail.forEach(p => {
    if (!p.activities) p.activities = [];
    p.activities.unshift({ date: today, type: 'email', notes: 'Batch email sent from Action Queue' });
    p.lastActivity = today;
    p.nextAction = 'Follow up';
    p.nextActionDate = followUpStr;
    if (p.stage !== 'contacted') {
      p.stage = 'contacted';
      p.activities.unshift({ date: today, type: 'stage', notes: `Moved to ${STAGE_LABELS['contacted']}` });
    }
  });
  savePipeline();
  _aqClear();
  renderBoard();
  updateHeaderSub();
  showToast(`\u2709 Gmail opened \u2014 ${withEmail.length} Action Queue recipient${withEmail.length !== 1 ? 's' : ''}`);
}

function _renderSecondarySection(stage, cards, bgColor, textColor, alertBadge) {
  return `
    <details class="secondary-section" ondragover="onDragOver(event,'${stage}')" ondrop="onDrop(event,'${stage}')" ondragleave="onDragLeave(event)">
      <summary style="display:flex;align-items:center;gap:10px;padding:10px 14px;background:${bgColor};border-radius:8px;cursor:pointer;border:1px solid ${textColor}30;user-select:none;list-style:none" onclick="event.stopPropagation()">
        <span style="font-size:13px">${STAGE_ICONS[stage]}</span>
        <span style="font-size:12px;font-weight:700;color:${textColor};letter-spacing:0.5px;text-transform:uppercase">${STAGE_LABELS[stage]}</span>
        <span style="font-size:11px;color:${textColor};opacity:0.7">${cards.length}</span>
        ${alertBadge}
        ${cards.length > 0 ? `<button onclick="event.stopPropagation();clearSecondaryStage('${stage}')" title="Remove all from this list" style="margin-left:auto;font-size:10px;padding:2px 8px;border-radius:4px;border:1px solid ${textColor}40;background:transparent;color:${textColor};cursor:pointer;font-family:'DM Sans',sans-serif;opacity:0.6">\u2715 Clear All</button>` : ''}
        <span style="${cards.length > 0 ? '' : 'margin-left:auto;'}font-size:10px;color:var(--text-dim)">\u25BC</span>
      </summary>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;padding:12px 8px;border:1px solid var(--border);border-top:none;border-radius:0 0 8px 8px;background:var(--card)" id="colbody-${stage}">
        ${cards.map(p => {
          const isOverdue = p.nextActionDate && new Date(p.nextActionDate+'T12:00:00') < new Date(new Date().setHours(0,0,0,0));
          return `<div style="position:relative;${isOverdue?'border-left:3px solid var(--accent);':''}">
            <button onclick="event.stopPropagation();removeProspect('${p.id}','${stage}')" title="Remove ${p.gymName}" style="position:absolute;top:4px;right:4px;background:rgba(0,0,0,0.5);border:none;color:var(--text-dim);font-size:10px;width:18px;height:18px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:2;opacity:0.5;transition:opacity 0.15s" onmouseover="this.style.opacity='1';this.style.color='var(--accent)'" onmouseout="this.style.opacity='0.5';this.style.color='var(--text-dim)'">\u2715</button>
            ${cardHTML(p)}
          </div>`;
        }).join('')}
        ${cards.length === 0 ? `<div style="grid-column:1/-1;text-align:center;padding:16px;color:var(--text-dim);font-size:11px">No prospects in this stage</div>` : ''}
      </div>
    </details>`;
}

function _ensurePortfolioData(p) {
  // Before removing a signed prospect from the pipeline, ensure their data is preserved
  // in deka_crm and deka_affiliates_added so the Portfolio Dashboard keeps them
  if (p.stage !== 'signed') return;
  const normName = s => (s||'').toLowerCase().replace(/[^a-z0-9]/g,'');
  const crmId = p.gymName.toLowerCase().replace(/[^a-z0-9]/g,'_').slice(0,20);

  // Ensure CRM entry exists with their info
  const crmData = JSON.parse(localStorage.getItem('deka_crm')||'{}');
  if (!crmData[crmId]) crmData[crmId] = {};
  Object.assign(crmData[crmId], {
    contactName: crmData[crmId].contactName || p.ownerName || '',
    email: crmData[crmId].email || p.email || '',
    phone: crmData[crmId].phone || p.phone || '',
    city: crmData[crmId].city || p.city || '',
    gymType: crmData[crmId].gymType || p.gymType || '',
  });
  // Preserve onboarding codes if they exist
  if (p.onboardingCodes && !crmData[crmId].onboardingCodes) {
    crmData[crmId].onboardingCodes = p.onboardingCodes;
  }
  localStorage.setItem('deka_crm', JSON.stringify(crmData));

  // Ensure they're in the affiliates_added list (skip if already in default roster)
  const roster = JSON.parse(localStorage.getItem('deka_affiliate_roster')||'[]');
  const inRoster = roster.some(r => normName(r.name) === normName(p.gymName));
  if (!inRoster) {
    const added = JSON.parse(localStorage.getItem('deka_affiliates_added')||'[]');
    if (!added.some(a => normName(a.name) === normName(p.gymName))) {
      added.push({
        id: crmId, name: p.gymName, state: p.state||'??', tier: 'd',
        signYear: new Date().getFullYear(), events: 0, participants: 0, revenue: 0,
        eventHistory: [], upcomingEvents: [], city: p.city||'', gymType: p.gymType||'',
      });
      localStorage.setItem('deka_affiliates_added', JSON.stringify(added));
    }
  }
}

function removeProspect(id, stage) {
  const p = pipelineData.prospects.find(x => x.id === id);
  if (!p) return;
  const msg = p.stage === 'signed'
    ? 'Remove ' + p.gymName + ' from the sales pipeline?\n\nTheir data is preserved in the Portfolio Dashboard.'
    : 'Remove ' + p.gymName + ' from the pipeline? This cannot be undone.';
  if (!confirm(msg)) return;
  _ensurePortfolioData(p);
  pipelineData.prospects = pipelineData.prospects.filter(x => x.id !== id);
  savePipeline();
  renderBoard();
  updateHeaderSub();
  if (p.stage === 'signed') showToast(p.gymName + ' removed from pipeline \u2014 preserved in Portfolio');
}

function clearSecondaryStage(stage) {
  const label = STAGE_LABELS[stage] || stage;
  const prospects = pipelineData.prospects.filter(p => p.stage === stage);
  if (prospects.length === 0) return;
  const msg = stage === 'signed'
    ? 'Remove all ' + prospects.length + ' signed gyms from the pipeline?\n\nTheir data is preserved in the Portfolio Dashboard.'
    : 'Remove all ' + prospects.length + ' prospects from "' + label + '"? This cannot be undone.';
  if (!confirm(msg)) return;
  // Ensure all signed prospects have their portfolio data preserved
  prospects.forEach(p => _ensurePortfolioData(p));
  pipelineData.prospects = pipelineData.prospects.filter(p => p.stage !== stage);
  savePipeline();
  renderBoard();
  updateHeaderSub();
  if (stage === 'signed') showToast(prospects.length + ' gyms removed from pipeline \u2014 all preserved in Portfolio');
}

function cardHTML(p) {
  const priClass = {hot:'pri-hot',warm:'pri-warm',cold:'pri-cold'}[p.priority] || 'pri-cold';
  const priLabel = {hot:'🔥 HOT',warm:'😊 WARM',cold:'❄ COLD'}[p.priority] || p.priority;
  const today = new Date(); today.setHours(0,0,0,0);
  const isOverdue = p.nextActionDate && new Date(p.nextActionDate+'T12:00:00') < today;
  const daysSince = p.lastActivity ? Math.floor((Date.now()-new Date(p.lastActivity+'T12:00:00'))/86400000) : null;
  const gmailUrl = p.email ? `https://mail.google.com/mail/?view=cm&to=${encodeURIComponent(p.email)}&su=${encodeURIComponent('DEKA Affiliate Partnership')}` : '';

  return `<div class="p-card${selectedIds.has(p.id)?' selected':''}" id="pcard-${p.id}" draggable="true"
    ondragstart="onDragStart(event,'${p.id}')"
    ondragend="onDragEnd(event)">
    <input type="checkbox" class="p-card-check" ${selectedIds.has(p.id)?'checked':''} onclick="event.stopPropagation();toggleSelect('${p.id}')" title="Select for batch action">
    <span class="priority-badge ${priClass}">${priLabel}</span>
    <div class="p-card-name">${esc(p.gymName)}</div>
    <div class="p-card-sub">${[p.city, p.state].filter(Boolean).join(', ')}${p.ownerName ? ' · '+esc(p.ownerName) : ''}</div>
    ${p.estimatedRevenue ? `<div class="p-card-meta">Est: $${Number(p.estimatedRevenue).toLocaleString()}/yr</div>` : ''}
    ${daysSince !== null ? `<div class="p-card-meta" style="color:${daysSince>14?'var(--accent)':'var(--text-dim)'}">Activity: ${daysSince===0?'Today':daysSince+'d ago'}</div>` : ''}
    ${p.nextAction ? `<div class="p-card-meta ${isOverdue?'overdue':''}">&#8594; ${esc(p.nextAction)}${p.nextActionDate?' · '+p.nextActionDate:''}</div>` : ''}
    <div class="p-card-actions">
      <button class="btn btn-ghost btn-sm" onclick="openDetail('${p.id}');event.stopPropagation()">View</button>
      <select class="flt" style="font-size:11px;padding:3px 6px" onchange="moveStage('${p.id}',this.value);event.stopPropagation()" title="Move stage">
        <option value="">Move &#8594;</option>
        ${STAGES.filter(s=>s!==p.stage).map(s=>`<option value="${s}">${STAGE_LABELS[s]}</option>`).join('')}
      </select>
      ${gmailUrl ? `<button class="btn btn-blue btn-sm" onclick="openGmail('${gmailUrl}');event.stopPropagation()">&#9993;</button>` : ''}
    </div>
  </div>`;
}

// ── DRAG & DROP ──
let draggingId = null;
function onDragStart(e, id) { draggingId = id; document.getElementById('pcard-'+id)?.classList.add('dragging'); }
function onDragEnd(e) { document.querySelectorAll('.p-card').forEach(c=>c.classList.remove('dragging')); }
function onDragOver(e, stage) { e.preventDefault(); document.getElementById('colbody-'+stage)?.classList.add('drag-over'); }
function onDragLeave(e) { document.querySelectorAll('.col-body').forEach(c=>c.classList.remove('drag-over')); }
function onDrop(e, stage) {
  e.preventDefault();
  document.querySelectorAll('.col-body').forEach(c=>c.classList.remove('drag-over'));
  if (draggingId) { moveStage(draggingId, stage); draggingId = null; }
}
function moveStage(id, stage) {
  const p = pipelineData.prospects.find(x=>x.id===id);
  if (p && p.stage !== stage) {
    p.stage = stage;
    p.lastActivity = new Date().toISOString().slice(0,10);
    if (!p.activities) p.activities = [];
    p.activities.unshift({date:p.lastActivity, type:'stage', notes:`Moved to ${STAGE_LABELS[stage]}`});
    savePipeline();
    renderBoard();
    updateHeaderSub();
    if (currentDetailId === id) openDetail(id);
  }
}

// ── PROSPECT LIST ──
function renderList() {
  const filtered = getFiltered(true);
  const active = filtered.filter(p => p.stage !== 'lost');
  const lost = filtered.filter(p => p.stage === 'lost');
  document.getElementById('prospect-count').textContent = `${active.length} active \u00b7 ${lost.length} closed lost`;
  const sorted = getSorted(active);

  const today = new Date(); today.setHours(0,0,0,0);

  const rowHTML = (p, dim) => {
    const priClass = {hot:'pri-hot',warm:'pri-warm',cold:'pri-cold'}[p.priority]||'pri-cold';
    const stageColor = `var(--stage-${p.stage})`;
    const isOverdue = p.nextActionDate && new Date(p.nextActionDate+'T12:00:00') < today;
    const daysSince = p.lastActivity ? Math.floor((Date.now()-new Date(p.lastActivity+'T12:00:00'))/86400000) : null;
    const score = prospectScore(p);
    return `<tr onclick="openDetail('${p.id}')" style="${dim?'opacity:0.5':''}">
      <td><span class="priority-badge ${priClass}" style="font-size:10px">${{hot:'🔥',warm:'😊',cold:'❄'}[p.priority]||''} ${p.priority||'—'}</span></td>
      <td><strong>${esc(p.gymName)}</strong>${p.gymType?'<br><span style="font-size:10px;color:var(--text-dim)">'+esc(p.gymType)+'</span>':''}</td>
      <td style="color:var(--text-dim)">${p.state||'—'}</td>
      <td>${p.ownerName?esc(p.ownerName):'<span style="color:var(--text-dim)">—</span>'}${p.email?'<br><span style="font-size:10px;color:var(--blue)">'+esc(p.email)+'</span>':''}</td>
      <td><span class="stage-pill" style="background:${stageColor}22;color:${stageColor}">${STAGE_LABELS[p.stage]||p.stage}</span></td>
      <td style="color:var(--text-dim);font-size:11px">${score}</td>
      <td style="color:${daysSince!==null&&daysSince>14?'var(--accent)':'var(--text-dim)'}">${daysSince!==null?(daysSince===0?'Today':daysSince+'d ago'):'—'}</td>
      <td style="color:${isOverdue?'var(--accent)':'var(--text-mid)'}">${p.nextAction?esc(p.nextAction):'—'}${p.nextActionDate?'<br><span style="font-size:10px">'+p.nextActionDate+'</span>':''}</td>
      <td onclick="event.stopPropagation()">
        <div style="display:flex;gap:4px">
          <button class="btn btn-ghost btn-sm" onclick="openDetail('${p.id}')">View</button>
          ${p.email?`<button class="btn btn-blue btn-sm" onclick="openGmail('https://mail.google.com/mail/?view=cm&to=${encodeURIComponent(p.email)}&su=${encodeURIComponent('DEKA Affiliate Partnership')}')">&#9993;</button>`:''}
        </div>
      </td>
    </tr>`;
  };

  const lostRows = lost.length ? `
    <tr onclick="this.nextElementSibling.style.display=this.nextElementSibling.style.display==='none'?'':'none'" style="cursor:pointer;background:var(--card2)">
      <td colspan="9" style="padding:10px 14px;font-size:12px;color:var(--text-dim);font-weight:600">
        🚫 Closed Lost (${lost.length}) — click to expand
      </td>
    </tr>
    ${lost.map(p => `<tr style="display:none">${rowHTML(p,true).replace('<tr ','<tr-inner ')}</tr>`).join('')}` : '';

  // Simpler lost section
  const lostSection = lost.length ? `
    <tr style="background:var(--card2)">
      <td colspan="9" style="padding:0">
        <details style="padding:0">
          <summary style="padding:10px 14px;font-size:12px;color:var(--text-dim);font-weight:600;cursor:pointer;list-style:none">
            🚫 Closed Lost (${lost.length}) &nbsp;▸ click to show
          </summary>
          <table style="width:100%;border-collapse:collapse">
            ${lost.map(p => rowHTML(p, true)).join('')}
          </table>
        </details>
      </td>
    </tr>` : '';

  document.getElementById('list-body').innerHTML =
    (sorted.length ? sorted.map(p => rowHTML(p, false)).join('') : '<tr><td colspan="9" style="text-align:center;padding:40px;color:var(--text-dim)">No active prospects match your filters.</td></tr>') +
    lostSection;
}

function sortList(col) {
  if (listSortCol === col) listSortDir = listSortDir === 'asc' ? 'desc' : 'asc';
  else { listSortCol = col; listSortDir = 'asc'; }
  renderList();
}

// ── ANALYTICS ──
function renderAnalytics() {
  loadPipeline();
  const all = pipelineData.prospects;
  const active = all.filter(p => p.stage !== 'lost');
  const signed = all.filter(p => p.stage === 'signed');
  const hot = all.filter(p => p.priority === 'hot' && p.stage !== 'lost');
  const totalPipelineValue = active.reduce((s,p) => s + (Number(p.estimatedRevenue)||0), 0);
  const goal = pipelineData.goals?.newAffiliates2026 || 8;
  const goalPct = Math.min(Math.round((signed.length/goal)*100), 100);

  // Stage counts
  const stageCounts = {};
  STAGES.forEach(s => stageCounts[s] = all.filter(p=>p.stage===s).length);
  const maxStage = Math.max(...Object.values(stageCounts), 1);

  // Source breakdown
  const sources = {};
  all.forEach(p => { if (p.source) sources[p.source] = (sources[p.source]||0)+1; });

  // Territory coverage — current affiliates by state (from portfolio dashboard via localStorage)
  const crmData = JSON.parse(localStorage.getItem('deka_crm')||'{}');
  const affiliateStates = {CT:3,MA:5,NY:3,NJ:2,PA:9,VA:3,MD:1,DC:1,RI:1,ME:1,NH:1,VT:0,DE:1};
  const maxAff = Math.max(...Object.values(affiliateStates), 1);

  document.getElementById('analytics-content').innerHTML = `
    <div class="kpi-row">
      <div class="kpi-box"><div class="kpi-val" style="color:var(--blue)">${active.length}</div><div class="kpi-lbl">Active Prospects</div></div>
      <div class="kpi-box"><div class="kpi-val" style="color:var(--accent)">${hot.length}</div><div class="kpi-lbl">Hot Leads</div></div>
      <div class="kpi-box"><div class="kpi-val" style="color:var(--green)">${signed.length}</div><div class="kpi-lbl">Signed in 2026</div></div>
      <div class="kpi-box"><div class="kpi-val" style="color:var(--yellow);font-size:20px">$${totalPipelineValue.toLocaleString()}</div><div class="kpi-lbl">Pipeline Value (Est.)</div></div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px">
      <div>
        <h3 style="font-size:13px;font-weight:700;margin-bottom:14px">Pipeline Funnel</h3>
        ${STAGES.filter(s=>s!=='lost').map(s => `
          <div class="funnel-bar">
            <div class="funnel-label">${STAGE_ICONS[s]} ${STAGE_LABELS[s]}</div>
            <div class="funnel-track">
              <div class="funnel-fill" style="width:${Math.max((stageCounts[s]/maxStage)*100,4)}%;background:var(--stage-${s})">
                ${stageCounts[s]>0?stageCounts[s]:''}
              </div>
            </div>
          </div>`).join('')}
        <div class="funnel-bar">
          <div class="funnel-label">🚫 Closed Lost</div>
          <div class="funnel-track">
            <div class="funnel-fill" style="width:${Math.max((stageCounts.lost/maxStage)*100,4)}%;background:var(--stage-lost);opacity:0.5">
              ${stageCounts.lost>0?stageCounts.lost:''}
            </div>
          </div>
        </div>
      </div>

      <div>
        <div class="goal-bar-wrap" style="margin-bottom:16px">
          <div style="display:flex;justify-content:space-between;align-items:baseline">
            <div style="font-size:13px;font-weight:700">2026 Signing Goal</div>
            <div style="font-size:22px;font-weight:700;color:var(--green)">${signed.length}<span style="font-size:13px;color:var(--text-dim)"> / ${goal}</span></div>
          </div>
          <div class="goal-track"><div class="goal-fill" style="width:${goalPct}%"></div></div>
          <div style="font-size:11px;color:var(--text-dim)">${goalPct}% to goal &nbsp;·&nbsp; ${Math.max(goal-signed.length,0)} more to reach target</div>
          <div style="margin-top:12px;font-size:12px;color:var(--text-dim)">
            <span style="cursor:pointer;text-decoration:underline" onclick="promptGoal()">Change goal (currently ${goal})</span>
          </div>
        </div>

        <h4 style="font-size:12px;font-weight:700;margin-bottom:10px;color:var(--text-mid)">Source Breakdown</h4>
        ${Object.entries(sources).sort((a,b)=>b[1]-a[1]).map(([src,cnt]) =>
          `<div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:6px;padding-bottom:6px;border-bottom:1px solid var(--border)">
            <span style="color:var(--text-mid)">${src}</span>
            <strong>${cnt}</strong>
          </div>`).join('') || '<div style="color:var(--text-dim);font-size:12px">No data yet.</div>'}
      </div>
    </div>

    <h3 style="font-size:13px;font-weight:700;margin-bottom:14px">Territory Coverage (Signed Affiliates)</h3>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:6px">
      ${NE_STATES.map(st => {
        const count = affiliateStates[st]||0;
        const pcts = Math.round((count/maxAff)*100);
        const isOpp = count === 0 || count === 1;
        return `<div class="territory-row">
          <div class="territory-state">${st}</div>
          <div class="territory-track"><div class="territory-fill" style="width:${Math.max(pcts,2)}%"></div></div>
          <div class="territory-count">${count} affiliate${count!==1?'s':''}</div>
          ${isOpp?'<div class="territory-opp">OPEN</div>':''}
        </div>`;
      }).join('')}
    </div>`;
}

function promptGoal() {
  const g = prompt('Set 2026 signing goal (number of new affiliates):', pipelineData.goals?.newAffiliates2026 || 8);
  if (g && !isNaN(parseInt(g))) {
    if (!pipelineData.goals) pipelineData.goals = {};
    pipelineData.goals.newAffiliates2026 = parseInt(g);
    savePipeline();
    renderAnalytics();
  }
}

// ── DETAIL PANEL ──
function openDetail(id) {
  loadPipeline();
  const p = pipelineData.prospects.find(x => x.id === id);
  if (!p) return;
  currentDetailId = id;

  const priClass = {hot:'pri-hot',warm:'pri-warm',cold:'pri-cold'}[p.priority]||'pri-cold';
  const priLabel = {hot:'🔥 HOT',warm:'😊 WARM',cold:'❄ COLD'}[p.priority]||'—';
  document.getElementById('dp-priority-badge').className = `priority-badge ${priClass}`;
  document.getElementById('dp-priority-badge').textContent = priLabel;
  document.getElementById('dp-name').textContent = p.gymName;
  document.getElementById('dp-sub').textContent = [p.city, p.state, p.gymType].filter(Boolean).join(' · ');

  const activities = (p.activities||[]).slice(0,8);
  const actIcons = {call:'📞',email:'✉',note:'📝',stage:'→',meeting:'🤝'};
  const gmailUrl = p.email ? `https://mail.google.com/mail/?view=cm&to=${encodeURIComponent(p.email)}&su=${encodeURIComponent('DEKA Affiliate Partnership')}` : '';

  document.getElementById('dp-body').innerHTML = `
    <div class="detail-section">
      <div class="detail-section-title">Stage & Priority</div>
      <div class="d-row">
        <div class="d-field">
          <label>Stage</label>
          <select id="dp-stage" onchange="dpSave()">
            ${STAGES.map(s=>`<option value="${s}"${p.stage===s?' selected':''}>${STAGE_ICONS[s]} ${STAGE_LABELS[s]}</option>`).join('')}
          </select>
        </div>
        <div class="d-field">
          <label>Priority</label>
          <select id="dp-priority" onchange="dpSave()">
            <option value="hot"${p.priority==='hot'?' selected':''}>🔥 Hot</option>
            <option value="warm"${p.priority==='warm'?' selected':''}>😊 Warm</option>
            <option value="cold"${p.priority==='cold'?' selected':''}>❄ Cold</option>
          </select>
        </div>
      </div>
    </div>

    <div class="detail-section">
      <div class="detail-section-title">Contact Info</div>
      <div class="d-row">
        <div class="d-field"><label>Owner / Contact</label><input id="dp-ownerName" value="${esc(p.ownerName||'')}" oninput="dpSave()" placeholder="Name"></div>
        <div class="d-field"><label>Email</label><input type="email" id="dp-email" value="${esc(p.email||'')}" oninput="dpSave()" placeholder="email@gym.com"></div>
        <div class="d-field"><label>Phone</label><input type="tel" id="dp-phone" value="${esc(p.phone||'')}" oninput="dpSave()" placeholder="(555) 555-1234"></div>
        <div class="d-field"><label>Gym Type</label>
          <select id="dp-gymType" onchange="dpSave()">
            <option value="">--</option>
            ${['CrossFit Box','YMCA','Boutique Fitness','Independent Gym','Martial Arts / MMA','Sports Complex','University / Rec Center','Other'].map(t=>`<option${p.gymType===t?' selected':''}>${t}</option>`).join('')}
          </select>
        </div>
        <div class="d-field"><label>City</label><input id="dp-city" value="${esc(p.city||'')}" oninput="dpSave()"></div>
        <div class="d-field"><label>State</label><input id="dp-state" value="${esc(p.state||'')}" oninput="dpSave()" maxlength="2" style="text-transform:uppercase"></div>
      </div>
    </div>

    <div class="detail-section">
      <div class="detail-section-title" style="display:flex;align-items:center">Deal Info <span id="dp-save-flash" style="font-size:10px;color:var(--green);margin-left:8px;opacity:0;transition:opacity 0.5s;font-weight:600;text-transform:none;letter-spacing:0">✓ Saved</span></div>
      <div class="d-row">
        <div class="d-field"><label>Source</label>
          <select id="dp-source" onchange="dpSave()">
            <option value="">--</option>
            ${['referral','cold','inbound','event','social','sheet'].map(s=>`<option value="${s}"${p.source===s?' selected':''}>${s}</option>`).join('')}
          </select>
        </div>
        <div class="d-field"><label>Est. Revenue / yr ($)</label><input type="number" id="dp-revenue" value="${p.estimatedRevenue||''}" oninput="dpSave()" placeholder="4000"></div>
        <div class="d-field"><label>Next Action</label><input id="dp-nextAction" value="${esc(p.nextAction||'')}" oninput="dpSave()" placeholder="Send partnership deck"></div>
        <div class="d-field">
          <label>Due Date</label>
          <input type="date" id="dp-nextActionDate" value="${p.nextActionDate||''}" oninput="dpSave()">
          <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:6px">
            <button class="btn btn-ghost btn-sm" style="font-size:11px;padding:3px 8px" onclick="setFollowUpDate(3)">+3 Days</button>
            <button class="btn btn-ghost btn-sm" style="font-size:11px;padding:3px 8px" onclick="setFollowUpDate(7)">+1 Week</button>
            <button class="btn btn-ghost btn-sm" style="font-size:11px;padding:3px 8px" onclick="setFollowUpDate(14)">+2 Weeks</button>
            <select class="flt" style="font-size:11px;padding:3px 6px" onchange="setFollowUpDate(this.value*30);this.selectedIndex=0" title="Set months out">
              <option value="">+ Months...</option>
              ${[1,2,3,4,5,6,9,12].map(m=>`<option value="${m}">${m} Month${m>1?'s':''}</option>`).join('')}
            </select>
          </div>
        </div>
      </div>
    </div>

    <div class="detail-section">
      <div class="detail-section-title">Notes</div>
      <div class="d-field"><textarea id="dp-notes" rows="3" oninput="dpSave()" placeholder="Context, objections, connections...">${esc(p.notes||'')}</textarea></div>
    </div>

    <div class="detail-section">
      <div class="detail-section-title">Activity Log (${activities.length} entries)</div>
      ${activities.map(a => `
        <div class="activity-item">
          <div class="activity-meta"><span>${actIcons[a.type]||'•'} ${a.type||'note'}</span><span>${a.date||''}</span></div>
          <div class="activity-notes">${esc(a.notes||'')}</div>
        </div>`).join('') || '<div style="color:var(--text-dim);font-size:12px;margin-bottom:10px">No activity logged yet.</div>'}
      <div class="log-form">
        <div class="detail-section-title" style="margin-bottom:8px">+ Log Activity</div>
        <div class="d-row" style="margin-bottom:8px">
          <div class="d-field"><label>Type</label>
            <select id="log-type">
              <option value="call">📞 Call</option>
              <option value="email">✉ Email</option>
              <option value="meeting">🤝 Meeting</option>
              <option value="note">📝 Note</option>
            </select>
          </div>
          <div class="d-field"><label>Date</label><input type="date" id="log-date" value="${new Date().toISOString().slice(0,10)}"></div>
        </div>
        <div class="d-field"><textarea id="log-notes" rows="2" placeholder="What happened? What did they say?"></textarea></div>
        <button class="btn btn-primary btn-sm" style="margin-top:6px" onclick="logActivity()">Log Activity</button>
      </div>
    </div>

    <div class="detail-section">
      <div class="detail-section-title">Email Templates</div>
      <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px">
        <button class="btn btn-ghost btn-sm" onclick="genEmail('cold')" title="🎯 Pain Call-Out + 💥 Big Promise — first touch">Cold Intro</button>
        <button class="btn btn-ghost btn-sm" onclick="genEmail('called')" title="🏅 Authority + Before/After Transformation — post-call">Called + Email</button>
        <button class="btn btn-ghost btn-sm" onclick="genEmail('followup')" title="🔓 Secret/Hack + 📋 Framework — nurture">Post-Call Follow-up</button>
        <button class="btn btn-ghost btn-sm" onclick="genEmail('discovery')" title="💥 Big Promise + ⏰ Urgency — close">Discovery Recap</button>
      </div>
      <div id="hook-indicator" style="display:none;margin-bottom:8px;padding:6px 10px;border-radius:6px;font-size:10px;line-height:1.5;border:1px solid #2C2C2C;background:#1C1C1C">
        <span id="hook-label" style="font-weight:600;letter-spacing:0.5px"></span>
        <span id="hook-why" style="color:#888;margin-left:6px"></span>
      </div>
      <div id="email-output-wrap" style="display:none">
        <div style="font-size:10px;color:var(--text-dim);margin-bottom:4px;display:flex;align-items:center;justify-content:space-between">
          <span id="email-type-label" style="font-weight:600;text-transform:uppercase;letter-spacing:0.5px"></span>
          <button class="email-regen-btn" onclick="regenEmail()" title="Generate a fresh variation of this email">↻ Regenerate</button>
        </div>
        <textarea class="email-output" id="email-output" rows="12" spellcheck="true"></textarea>
        <div class="email-actions">
          <button class="btn btn-ghost btn-sm" onclick="copyEmail()">📋 Copy</button>
          ${p.email ? `<button class="btn btn-blue btn-sm" onclick="openEmailInGmail('${p.id}')">✉ Open in Gmail</button>` : ''}
        </div>
      </div>
    </div>`;

  document.getElementById('dp-footer').innerHTML = `
    <button class="btn btn-ghost btn-sm" style="color:var(--accent)" onclick="archiveProspect('${p.id}')">🚫 Close Lost</button>
    <button class="btn btn-ghost btn-sm" onclick="deleteProspect('${p.id}')">🗑 Delete</button>
    <div style="flex:1"></div>
    ${p.stage !== 'signed'
      ? `<button class="btn btn-primary signed-btn" onclick="markSigned('${p.id}')">✅ Mark as Signed → Add to Portfolio</button>`
      : `<div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
           <div style="color:var(--green);font-size:12px;font-weight:600">✅ Signed</div>
           <button class="btn btn-ghost" style="font-size:11px;padding:4px 10px;border-color:var(--green);color:var(--green)" onclick="openOnboardingFromDetail('${p.id}')">📋 Onboarding Checklist</button>
         </div>`
    }`;

  document.getElementById('detail-overlay').classList.add('open');
}

function closeDetail(e) {
  if (!e || e.target === document.getElementById('detail-overlay')) {
    document.getElementById('detail-overlay').classList.remove('open');
    currentDetailId = null;
  }
}

function setFollowUpDate(days) {
  const input = document.getElementById('dp-nextActionDate');
  if (!input) return;
  const d = new Date();
  d.setDate(d.getDate() + Math.round(Number(days)));
  input.value = d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');
  dpSave();
}

function dpSave() {
  if (!currentDetailId) return;
  const p = pipelineData.prospects.find(x => x.id === currentDetailId);
  if (!p) return;
  const get = id => { const el = document.getElementById(id); return el ? el.value : ''; };
  const newStage = get('dp-stage');
  if (newStage && newStage !== p.stage) {
    if (!p.activities) p.activities = [];
    p.activities.unshift({date:new Date().toISOString().slice(0,10), type:'stage', notes:`Moved to ${STAGE_LABELS[newStage]}`});
  }
  Object.assign(p, {
    stage: newStage||p.stage, priority: get('dp-priority')||p.priority,
    ownerName: get('dp-ownerName'), email: get('dp-email'), phone: get('dp-phone'),
    gymType: get('dp-gymType'), city: get('dp-city'), state: get('dp-state').toUpperCase(),
    source: get('dp-source'), estimatedRevenue: get('dp-revenue')||p.estimatedRevenue,
    nextAction: get('dp-nextAction'), nextActionDate: get('dp-nextActionDate'),
    notes: get('dp-notes'),
  });
  savePipeline();
  if (currentView === 'board') renderBoard();
  else if (currentView === 'list') renderList();
  // Flash save confirmation
  const _flash = document.getElementById('dp-save-flash');
  if (_flash) {
    clearTimeout(_flash._t);
    _flash.style.opacity = '1';
    _flash._t = setTimeout(() => { _flash.style.opacity = '0'; }, 1500);
  }
  // Update header badge in detail panel
  const priClass = {hot:'pri-hot',warm:'pri-warm',cold:'pri-cold'}[p.priority]||'pri-cold';
  const priLabel = {hot:'🔥 HOT',warm:'😊 WARM',cold:'❄ COLD'}[p.priority]||'—';
  const badge = document.getElementById('dp-priority-badge');
  if (badge) { badge.className = `priority-badge ${priClass}`; badge.textContent = priLabel; }
  updateHeaderSub();
}

function logActivity() {
  if (!currentDetailId) return;
  const p = pipelineData.prospects.find(x => x.id === currentDetailId);
  if (!p) return;
  const notes = document.getElementById('log-notes')?.value?.trim();
  const type = document.getElementById('log-type')?.value || 'note';
  const date = document.getElementById('log-date')?.value || new Date().toISOString().slice(0,10);
  if (!notes) return;
  if (!p.activities) p.activities = [];
  p.activities.unshift({date, type, notes});
  p.lastActivity = date;
  savePipeline();
  document.getElementById('log-notes').value = '';
  openDetail(currentDetailId);
}

function archiveProspect(id) {
  moveStage(id, 'lost');
  closeDetail();
}

function deleteProspect(id) {
  if (!confirm('Permanently delete this prospect?')) return;
  pipelineData.prospects = pipelineData.prospects.filter(p => p.id !== id);
  savePipeline();
  closeDetail();
  renderBoard();
  updateHeaderSub();
}

// markSigned() is now defined above near the onboarding modal code

// ── EMAIL GENERATORS ──
let _currentEmailType = 'cold';
let _emailVariant = 0;
const CALENDAR_LINK = _s('calendarLink','https://calendar.app.google/KtfQhJTg9wmrJhvs6');

function genEmail(type) {
  _currentEmailType = type;
  _emailVariant = 0;
  _renderEmail();
}
function regenEmail() {
  _emailVariant++;
  _renderEmail();
}

function _pick(arr, seed) {
  return arr[(seed || _emailVariant) % arr.length];
}

function _renderEmail() {
  const p = pipelineData.prospects.find(x => x.id === currentDetailId);
  if (!p) return;

  const firstName  = (p.ownerName||'').split(' ')[0] || 'there';
  const gym        = p.gymName || 'your gym';
  const city       = p.city   || '';
  const state      = p.state  || 'the ' + _s('region','Northeast');
  const gymType    = (p.gymType||'').toLowerCase();
  const isCF       = gymType.includes('crossfit') || gymType.includes('cf ');
  const isFunctional = gymType.includes('functional') || gymType.includes('hybrid') || gymType.includes('strength');
  const isHYROX    = gymType.includes('hyrox');
  const loc        = [city, state].filter(Boolean).join(', ');

  // Gym-type-aware angle line
  const gymLine = isCF
    ? `CrossFit communities are a natural fit. The competitive mindset is already there -- DEKA just gives it an official stage.`
    : isHYROX
    ? `Given that your members are already training for HYROX, hosting a DEKA event is a natural next step -- same audience, different badge, more revenue staying local.`
    : isFunctional
    ? `Functional fitness gyms are exactly the profile we look for. Your members are already training the right way -- DEKA gives that training a measurable outcome.`
    : `The gyms that do best with this already have a strong, engaged community. From what I can see, ${gym} fits that profile.`;

  // Local event hook (makes email feel researched)
  const localHook = city
    ? `people in ${city} are already registering for DEKA events in the ${_s('region','Northeast')}`
    : `members from gyms across the region are already signing up for DEKA events`;

  let subject = '', body = '';

  if (_currentEmailType === 'cold') {
    const openings = [
      `Hi ${firstName},\n\nMy name is ${_s('firstName','Anthony')}. I am the ${_s('region','Northeast')} Affiliate Manager for DEKA.\n\nI'm reaching out because ${localHook} -- across the ${_s('region','Northeast')}.`,
      `Hi ${firstName},\n\nI'll keep this brief. My name is ${_s('firstName','Anthony')} -- I run affiliate partnerships for DEKA across the ${_s('region','Northeast')}.\n\nI reached out because ${localHook}, and ${gym} kept coming up as a facility worth talking to.`,
      `Hi ${firstName},\n\nQuick note. I'm ${_s('firstName','Anthony')}, the ${_s('region','Northeast')} Affiliate Manager for DEKA.\n\n${gym} came across my radar when I was mapping out which gyms in ${state||'the region'} have the right profile for what we're building here.`,
    ];
    const hooks = [
      `If you are not familiar with DEKA yet, it's from the creators of Spartan Race and Tough Mudder, and it's fast becoming the go-to Hybrid Fitness Event around the globe.\n\nThis also tells us something important.\n\nPeople that you train already are:\n• Training for a hybrid style events, like DEKA + HYROX\n• Signing up for competitive fitness events around your area\n• And investing in experiences outside your four walls\n\nThe question is: are you capturing that momentum inside your facility?`,
      `DEKA is from the creators of Spartan Race and Tough Mudder. But here's what matters for you:\n\nYour members are already signing up for hybrid fitness events. The training happens in your gym. The revenue goes somewhere else.\n\nHosting a DEKA event changes that dynamic. You become the event -- not just the preparation for it.`,
      `You may have seen DEKA or HYROX events picking up in the area. That's not a trend -- it's a permanent shift in how gym members want to train and compete.\n\nThe gyms that position early as local hosts lock in the community gravity. The ones that wait end up watching members drive 45 minutes to compete at someone else's facility.`,
    ];
    const closes = [
      `This is why you should consider becoming a DEKA Affiliate. Because by doing so, you can:\n\n• Create a standardized benchmark your members can train toward\n• Gain hosting rights for OFFICIAL DEKA STRONG / MILE / and ATLAS events\n• Generate a new revenue stream (60% event revenue stays with you)\n• Build a retention system around measurable progression\n\nInstead of your members traveling to compete elsewhere, you become the centralized hub.\n\nYou already have the community...\nDEKA simply gives it structure, visibility, and monetization.\n\nIf you're open to it, I'd love to schedule a short discovery call. No pressure -- just clarity.\n\nSchedule a time to talk today: ${CALENDAR_LINK}\n\nLooking to connect soon,\n${_s('emailSignature','Anthony\\nDEKA Northeast Affiliate Manager')}`,
      `${gymLine}\n\nWhat the affiliate program gives you:\n• Hosting rights for Official DEKA STRONG / MILE / and ATLAS events\n• 60% of event revenue stays with your gym\n• A benchmark your members can actually train toward\n• Retention built around progression, not just motivation\n\nIf you're open to a 20-minute call, I'll walk you through exactly what it looks like for a gym like yours. No commitment -- just a conversation.\n\nBook a time here: ${CALENDAR_LINK}\n\nLooking forward to connecting,\n${_s('emailSignature','Anthony\\nDEKA Northeast Affiliate Manager')}`,
      `${gymLine}\n\nHere's the short version of what this looks like:\n\n• You host 1-2 DEKA events per year inside your facility\n• 60% of ticket revenue goes directly to you\n• We handle the event infrastructure, scoring, and certification\n• Your members get an official competitive outlet -- without leaving your gym\n\nWorth a quick call to see if it fits? Schedule here: ${CALENDAR_LINK}\n\nNo pressure. Worst case, you'll know exactly what your members are signing up for when they drive 40 minutes to compete in someone else's gym.\n\n${_s('emailSignature','Anthony\\nDEKA Northeast Affiliate Manager')}`,
    ];
    subject = `DEKA Affiliate Opportunity -- ${gym}`;
    body = `${_pick(openings)}\n\n${_pick(hooks)}\n\n${_pick(closes)}`;

  } else if (_currentEmailType === 'called') {
    const opens = [
      `Hi ${firstName},\n\nMy name is ${_s('firstName','Anthony')}. I am the ${_s('region','Northeast')} Affiliate Manager for DEKA.\n\nIf you're not yet familiar with DEKA -- it's from the creators of Spartan Race and Tough Mudder, and it's fast becoming the go-to Hybrid Fitness Event around the globe.\n\nI called earlier to touch base on the hybrid fitness events your members are signing up for.`,
      `Hi ${firstName},\n\n${_s('firstName','Anthony')} here -- I tried to reach you earlier. I'm the ${_s('region','Northeast')} Affiliate Manager for DEKA.\n\nI'll give you the short version since I couldn't catch you on the phone.`,
      `Hi ${firstName},\n\nJust tried you on the phone -- wanted to follow up in writing since this is easier to forward or revisit.\n\nI'm ${_s('firstName','Anthony')}, the ${_s('region','Northeast')} Affiliate Manager for DEKA (from the creators of Spartan Race and Tough Mudder).`,
    ];
    subject = `I called earlier -- DEKA Affiliate Opportunity for ${gym}`;
    body = `${_pick(opens)}\n\nBecause your members are registering for events like DEKA FIT and HYROX, it tells us something important.\n\nPeople that you train already are:\n• Training for hybrid style events\n• Signing up for competitive fitness events around your area\n• Investing in experiences outside your four walls\n\nThe question is: are you capturing that momentum inside your facility?\n\nIt's also why ${gym} keeps appearing on our radar as a strong fit. We're currently looking for a few high-caliber "Anchor Hubs" in ${state||'the region'} to host official DEKA STRONG, MILE, and ATLAS events.\n\nWhich means you can:\n\n• Create a standardized benchmark your members can train toward\n• Gain hosting rights for Official DEKA events\n• Generate a new revenue stream (60% event revenue stays with you)\n• Build a retention system around measurable progression\n\nInstead of your members traveling to compete elsewhere, you become the hub.\n\nYou already have the community.\nDEKA gives it structure, visibility, and monetization.\n\nIf you're open to it, I'd love a short discovery call:\n• Learn more about you and your gym\n• Share what we're seeing in the growth of hybrid fitness in ${state||'the Northeast'}\n• Walk through the affiliate model\n• See if it fits your facility and growth goals\n\nNo pressure -- just clarity. Schedule a time here: ${CALENDAR_LINK}\n\nLooking forward to connecting,\n${_s('emailSignature','Anthony\\nDEKA Northeast Affiliate Manager')}`;

  } else if (_currentEmailType === 'followup') {
    const opens = [
      `Hi ${firstName},\n\nGreat connecting today.\n\nJust to recap -- I work with DEKA (the fitness event series Spartan Race created) and part of my role is helping identify gyms that might be a good fit to host our official DEKA Hybrid fitness events locally.`,
      `Hi ${firstName},\n\nReally appreciate you making time today.\n\nQuick recap on my end: I work with DEKA to build out our affiliate network across the ${_s('region','Northeast')}, and part of that is finding gyms that have the community and setup to actually pull off what we do well.`,
      `Hi ${firstName},\n\nGood talking earlier.\n\nTo put context around the conversation -- my role at DEKA is to identify the right gyms in the ${_s('region','Northeast')} that can host our official events locally.`,
    ];
    const middles = [
      `When I came across ${gym}, it looked like the kind of facility that could actually pull something like this off.\n\nNot every gym can.\n\nWhat we've been seeing lately is that members love having something measurable to train for, and gyms hosting these events end up creating a lot of energy -- both leading up to and after the event. It becomes part competition, part community event.\n\nI'm currently looking for a few new affiliates in the region and your facility checks all the boxes.`,
      `${gymLine}\n\nThe gyms that do this well aren't the biggest or the most equipped -- they're the ones with a coach who gives a damn and a community that shows up for each other. That's what I saw when I looked at ${gym}.\n\nHosting a DEKA event becomes a moment for your gym, not just a workout. It creates energy, drives new member interest, and gives your regulars something to build toward.`,
      `Here's what I've seen consistently across the gyms that run these events: the energy it creates inside the facility is as valuable as the revenue. Members who compete together stay together.\n\n${gymLine}\n\nThe revenue split (60% to you) is real -- but the retention play is what most owners tell me they didn't expect.`,
    ];
    subject = `Good connecting today -- next steps for ${gym}`;
    body = `${_pick(opens)}\n\n${_pick(middles)}\n\nThe next step is to grab a 20-30 minute call to dig into the program a bit more.\n\nBook a call here: ${CALENDAR_LINK}\n\nWorst case, you'll leave knowing exactly whether something like this makes sense for your gym or not.\n\nLooking forward to connecting,\n${_s('emailSignature','Anthony\\nDEKA Northeast Affiliate Manager')}`;

  } else if (_currentEmailType === 'discovery') {
    subject = `CONGRATULATIONS -- ${gym} Has Been Approved for DEKA Affiliation`;
