    subject: 'DEKA \u2014 Let\u2019s schedule your onboarding strategy call',
    body: `Hey NAME,

Now that you\u2019ve had some time to explore the Affiliate Toolkit, I\u2019d love to set up a 30-minute video call to:

\u2022 Answer any questions you have about the toolkit and program
\u2022 Walk through the first half of our "Step by Step to Hosting a Successful Event" slide deck
\u2022 Talk through the Affiliate Service Form process and what to expect
\u2022 Start planning your first DEKA event together

This call is all about making sure you feel confident and supported as you get ready to host.

Here are a few times that work on my end \u2014 let me know what works best for you, or feel free to suggest another time:

[SUGGEST 2-3 TIMES]

Looking forward to connecting!

${_s('firstName','Anthony')}
DEKA ${_s('region','Northeast')} Affiliate Manager`
  },
};

function markSigned(id) {
  const p = pipelineData.prospects.find(x => x.id === id);
  if (!p) return;
  moveStage(id, 'signed');

  // Pre-fill CRM entry in main dashboard
  const crmData = JSON.parse(localStorage.getItem('deka_crm')||'{}');
  const crmId = p.gymName.toLowerCase().replace(/[^a-z0-9]/g,'_').slice(0,20);
  crmData[crmId] = Object.assign(crmData[crmId]||{}, {
    contactName: p.ownerName||'', email: p.email||'', phone: p.phone||'',
    city: p.city||'', gymType: p.gymType||'',
    notes: `[Signed via pipeline ${new Date().toISOString().slice(0,10)}]\n${p.notes||''}`,
    joinDate: new Date().toISOString().slice(0,10),
  });
  localStorage.setItem('deka_crm', JSON.stringify(crmData));

  // Ensure onboarding tasks exist on this prospect
  if (!p.onboardingTasks || p.onboardingTasks.length === 0) {
    p.onboardingTasks = JSON.parse(JSON.stringify(DEFAULT_ONBOARDING_TASKS));
    p.onboardingStart = new Date().toISOString().slice(0,10);
    savePipeline();
  }

  // Auto-transfer to portfolio
  transferToPortfolio(id);

  // Prospect is now signed — hide from active board and open onboarding
  openOnboardingModal(id);
}

function openOnboardingModal(id) {
  const p = pipelineData.prospects.find(x => x.id === id);
  if (!p) return;
  const crmId = p.gymName.toLowerCase().replace(/[^a-z0-9]/g,'_').slice(0,20);

  // Migrate old task structure (24 tasks) to new (11 tasks)
  if (!p.onboardingTasks || p.onboardingTasks.length > 11 || (p.onboardingTasks[0] && p.onboardingTasks[0].id === 'ob1' && !p.onboardingTasks[0].hasOwnProperty('emailBtn') && p.onboardingTasks.length > 11)) {
    p.onboardingTasks = JSON.parse(JSON.stringify(DEFAULT_ONBOARDING_TASKS));
    if (!p.onboardingStart) p.onboardingStart = new Date().toISOString().slice(0,10);
    savePipeline();
  }

  const tasks = p.onboardingTasks || DEFAULT_ONBOARDING_TASKS;
  const byWeek = [1,2].map(w => ({week:w, tasks: tasks.filter(t=>t.week===w)}));
  const doneCount = tasks.filter(t=>t.done).length;
  const codes = p.onboardingCodes || {};

  let el = document.getElementById('onboarding-modal');
  if (!el) {
    el = document.createElement('div');
    el.id = 'onboarding-modal';
    el.style.cssText = 'display:none;position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:1000;overflow-y:auto;padding:24px';
    document.body.appendChild(el);
  }

  const pct = tasks.length ? Math.round((doneCount/tasks.length)*100) : 0;
  const alreadyTransferred = JSON.parse(localStorage.getItem('deka_affiliates_added')||'[]').some(a => a.id === crmId);

  el.innerHTML = `
    <div style="max-width:660px;margin:0 auto;background:var(--card);border-radius:14px;padding:26px;border:1px solid var(--border)">

      <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:18px">
        <div>
          <div style="font-size:19px;font-weight:700;color:var(--green);cursor:pointer;text-decoration:underline;text-decoration-style:dotted;text-underline-offset:3px" onclick="openGymProfile('${id}')" title="Click to edit profile">\u2705 ${esc(p.gymName)}</div>
          <div style="font-size:12px;color:var(--text-dim);margin-top:3px">
            ${[p.city,p.state,p.gymType].filter(Boolean).join(' \u00b7 ')} \u00b7 Signed ${p.onboardingStart||new Date().toISOString().slice(0,10)}
            <span onclick="openGymProfile('${id}')" style="color:var(--blue);cursor:pointer;margin-left:8px;font-size:11px">\u270F\uFE0F Edit Profile</span>
          </div>
        </div>
        <button onclick="closeOnboardingModal()" style="background:none;border:none;color:var(--text-dim);font-size:22px;cursor:pointer;line-height:1;padding:0">\u2715</button>
      </div>

      <div style="background:${alreadyTransferred?'rgba(74,222,128,0.08)':'rgba(96,165,250,0.08)'};border:1px solid ${alreadyTransferred?'var(--green)':'var(--blue)'};border-radius:10px;padding:16px;margin-bottom:20px">
        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-dim);margin-bottom:10px">Portfolio Dashboard</div>
        ${alreadyTransferred
          ? `<div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
               <span style="color:var(--green);font-size:13px;font-weight:600">\u2713 Added to Portfolio Dashboard</span>
               <button onclick="window.open('index.html')" class="btn btn-ghost" style="font-size:12px;border-color:var(--green);color:var(--green)">Open Dashboard \u2192</button>
               <button onclick="openEventPlannerFromPipeline('${esc(p.gymName)}')" class="btn btn-ghost" style="font-size:12px;border-color:#4ade80;color:#4ade80">\uD83C\uDFC3 Plan First Event</button>
             </div>`
          : `<p style="font-size:12px;color:var(--text-mid);margin:0 0 12px">One click adds ${esc(p.gymName)} to your Portfolio Dashboard. Their contact info is already saved and waiting.</p>
             <button onclick="transferToPortfolio('${id}')" class="btn btn-primary" style="background:var(--blue);border-color:var(--blue);font-size:13px">\u2192 Add to Portfolio Dashboard</button>`
        }
      </div>

      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
        <div style="font-size:13px;font-weight:700">Onboarding Checklist</div>
        <div style="font-size:12px;color:var(--text-dim)" id="ob-count-label">${doneCount} / ${tasks.length} complete</div>
      </div>
      <div style="background:var(--bg);border-radius:6px;height:5px;margin-bottom:16px;overflow:hidden">
        <div id="ob-progress-bar" style="background:var(--green);height:100%;width:${pct}%;transition:width 0.3s"></div>
      </div>

      ${byWeek.map(({week, tasks:wt}) => `
        <div style="margin-bottom:16px">
          <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:${week===1?'var(--accent)':'var(--blue)'};margin-bottom:8px;padding-bottom:4px;border-bottom:1px solid var(--border)">${week===1?'Phase 1 \u2014 Setup & Admin':'Phase 2 \u2014 Outreach & Event Launch'}</div>
          ${wt.map(t => `
            <div style="padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.05)">
              <label style="display:flex;align-items:center;gap:10px;cursor:pointer">
                <input type="checkbox" ${t.done?'checked':''} onchange="toggleOBTask('${id}','${t.id}',this.checked)"
                  style="width:16px;height:16px;accent-color:var(--green);cursor:pointer;flex-shrink:0">
                <span style="font-size:12px;color:${t.done?'var(--text-dim)':'var(--text)'};${t.done?'text-decoration:line-through':''}; flex:1">${esc(t.label)}</span>
                ${t.done&&t.doneDate?`<span style="font-size:10px;color:var(--text-dim);flex-shrink:0">${t.doneDate}</span>`:''}
              </label>
              ${t.emailBtn?`
                <button onclick="openOBEmail('${id}','${t.emailBtn}')" style="margin:6px 0 0 26px;font-size:11px;padding:4px 12px;border-radius:5px;border:1px solid var(--blue);background:rgba(43,127,224,0.1);color:var(--blue);cursor:pointer;font-family:'DM Sans',sans-serif">
                  \u2709\uFE0F Open in Gmail
                </button>`:''}
              ${t.hasCodeField?`
                <div style="margin:8px 0 0 26px;display:grid;grid-template-columns:1fr 1fr;gap:6px">
                  <input id="ob-code-deka" value="${esc(codes.deka||'')}" placeholder="DEKA codes (x2)" style="font-size:11px;padding:5px 8px;background:var(--bg);border:1px solid var(--border);border-radius:5px;color:var(--text);font-family:'DM Sans',sans-serif">
                  <input id="ob-code-sgx" value="${esc(codes.sgx||'')}" placeholder="SGX code (x1)" style="font-size:11px;padding:5px 8px;background:var(--bg);border:1px solid var(--border);border-radius:5px;color:var(--text);font-family:'DM Sans',sans-serif">
                  <input id="ob-code-dekafit" value="${esc(codes.dekafit||'')}" placeholder="DEKA FIT 20% code" style="font-size:11px;padding:5px 8px;background:var(--bg);border:1px solid var(--border);border-radius:5px;color:var(--text);font-family:'DM Sans',sans-serif">
                  <input id="ob-code-spartan" value="${esc(codes.spartan||'')}" placeholder="Spartan 30% code" style="font-size:11px;padding:5px 8px;background:var(--bg);border:1px solid var(--border);border-radius:5px;color:var(--text);font-family:'DM Sans',sans-serif">
                </div>
                <button onclick="saveOBCodes('${id}')" style="margin:6px 0 0 26px;font-size:10px;padding:3px 10px;border-radius:4px;border:1px solid var(--green);background:rgba(29,185,84,0.1);color:var(--green);cursor:pointer;font-family:'DM Sans',sans-serif">\u2713 Save Codes</button>
              `:''}
            </div>`).join('')}
        </div>`).join('')}

      <div style="display:flex;justify-content:flex-end;margin-top:18px">
        <button onclick="closeOnboardingModal()" class="btn btn-ghost">Close</button>
      </div>
    </div>`;

  el.style.display = 'block';
}

function closeOnboardingModal() {
  const el = document.getElementById('onboarding-modal');
  if (el) el.style.display = 'none';
}

function transferToPortfolio(id) {
  const p = pipelineData.prospects.find(x => x.id === id);
  if (!p) return;
  const normName = s => (s||'').toLowerCase().replace(/[^a-z0-9]/g,'');
  let crmId = p.gymName.toLowerCase().replace(/[^a-z0-9]/g,'_').slice(0,20);

  // Check if this gym already exists in the portfolio roster (prevents duplicates)
  let roster;
  try { roster = JSON.parse(localStorage.getItem('deka_affiliate_roster') || '[]'); } catch(e) { roster = []; }
  const rosterMatch = roster.find(r => normName(r.name) === normName(p.gymName));
  if (rosterMatch) {
    // Gym already exists in the portfolio — use their existing ID and just update CRM data
    crmId = rosterMatch.id;
    const crmData = JSON.parse(localStorage.getItem('deka_crm')||'{}');
    crmData[crmId] = Object.assign(crmData[crmId]||{}, {
      contactName: p.ownerName||'', email: p.email||'', phone: p.phone||'',
      city: p.city||'', gymType: p.gymType||'',
    });
    localStorage.setItem('deka_crm', JSON.stringify(crmData));
    showToast(`${p.gymName} already exists in portfolio — CRM data updated`);
    openOnboardingModal(id);
    return;
  }

  // Also check deka_affiliates_added by name (not just ID)
  const added = JSON.parse(localStorage.getItem('deka_affiliates_added') || '[]');
  const addedMatch = added.find(a => normName(a.name) === normName(p.gymName));
  if (addedMatch) {
    crmId = addedMatch.id;
    showToast(`${p.gymName} already in portfolio — updated`);
    openOnboardingModal(id);
    return;
  }

  const newAffiliate = {
    id: crmId,
    name: p.gymName,
    state: p.state || '??',
    tier: 'b',
    signYear: new Date().getFullYear(),
    events: 0,
    participants: 0,
    revenue: Number(p.estimatedRevenue) || 0,
    eventHistory: [],
    upcomingEvents: [],
    city: p.city || '',
    gymType: p.gymType || '',
  };
  const existIdx = added.findIndex(a => a.id === crmId);
  if (existIdx >= 0) added[existIdx] = newAffiliate;
  else added.push(newAffiliate);
  localStorage.setItem('deka_affiliates_added', JSON.stringify(added));
  // Refresh modal to show the ✓ transferred state
  openOnboardingModal(id);
  // Open portfolio dashboard in new tab
  window.open('index.html');
}

function toggleOBTask(prospectId, taskId, checked) {
  const p = pipelineData.prospects.find(x => x.id === prospectId);
  if (!p || !p.onboardingTasks) return;
  const task = p.onboardingTasks.find(t => t.id === taskId);
  if (!task) return;
  task.done = checked;
  task.doneDate = checked ? new Date().toISOString().slice(0,10) : '';
  savePipeline();
  // Re-render the full modal so strikethrough + colors update correctly
  openOnboardingModal(prospectId);
}

function openOBEmail(prospectId, emailKey) {
  const p = pipelineData.prospects.find(x => x.id === prospectId);
  if (!p) return;
  const tmpl = ONBOARDING_EMAILS[emailKey];
  if (!tmpl) return;
  const firstName = (p.ownerName||'').split(' ')[0] || 'there';
  let body = tmpl.body.replace(/NAME/g, firstName);
  // Insert saved codes if available
  if (emailKey === 'codes' && p.onboardingCodes) {
    const c = p.onboardingCodes;
    body = body.replace('DEKA Certification Codes (x2): CODES_HERE', `DEKA Certification Codes (x2): ${c.deka||'[enter codes]'}`);
    body = body.replace('SGX Certification Code (x1): CODES_HERE', `SGX Certification Code (x1): ${c.sgx||'[enter code]'}`);
    body = body.replace('DEKA FIT 20% Discount Code: CODES_HERE', `DEKA FIT 20% Discount Code: ${c.dekafit||'[enter code]'}`);
    body = body.replace('Spartan Race 30% Discount Code: CODES_HERE', `Spartan Race 30% Discount Code: ${c.spartan||'[enter code]'}`);
  }
  const subject = tmpl.subject.replace(/NAME/g, firstName);
  const gmailUrl = `https://mail.google.com/mail/?view=cm&to=${encodeURIComponent(p.email||'')}&su=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  window.open(gmailUrl, '_blank');
}

function saveOBCodes(prospectId) {
  const p = pipelineData.prospects.find(x => x.id === prospectId);
  if (!p) return;
  p.onboardingCodes = {
    deka: document.getElementById('ob-code-deka')?.value?.trim() || '',
    sgx: document.getElementById('ob-code-sgx')?.value?.trim() || '',
    dekafit: document.getElementById('ob-code-dekafit')?.value?.trim() || '',
    spartan: document.getElementById('ob-code-spartan')?.value?.trim() || '',
  };
  savePipeline();
  showToast('Codes saved');
}

function openGymProfile(prospectId) {
  const p = pipelineData.prospects.find(x => x.id === prospectId);
  if (!p) return;
  let panel = document.getElementById('gym-profile-panel');
  if (!panel) {
    panel = document.createElement('div');
    panel.id = 'gym-profile-panel';
    panel.style.cssText = 'position:fixed;top:0;right:-420px;width:400px;height:100%;background:var(--card);border-left:1px solid var(--border);z-index:1100;overflow-y:auto;transition:right 0.3s ease;padding:24px;box-shadow:-4px 0 20px rgba(0,0,0,0.5)';
    document.body.appendChild(panel);
  }

  const fields = [
    {key:'gymName', label:'Gym Name'},
    {key:'ownerName', label:'Owner / Contact'},
    {key:'email', label:'Email'},
    {key:'phone', label:'Phone'},
    {key:'city', label:'City'},
    {key:'state', label:'State'},
    {key:'gymType', label:'Gym Type'},
    {key:'notes', label:'Notes', type:'textarea'},
  ];

  panel.innerHTML = `
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
      <div style="font-size:16px;font-weight:700;color:var(--green)">${esc(p.gymName)}</div>
      <button onclick="closeGymProfile()" style="background:none;border:none;color:var(--text-dim);font-size:20px;cursor:pointer">\u2715</button>
    </div>
    <div style="font-size:10px;color:var(--text-dim);letter-spacing:1px;text-transform:uppercase;margin-bottom:14px">Affiliate Profile</div>
    ${fields.map(f => `
      <div style="margin-bottom:12px">
        <div style="font-size:10px;color:var(--text-dim);letter-spacing:0.5px;margin-bottom:4px;font-weight:600">${f.label}</div>
        ${f.type === 'textarea'
          ? `<textarea id="gp-${f.key}" style="width:100%;background:var(--bg);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:12px;padding:8px;resize:vertical;min-height:80px;font-family:'DM Sans',sans-serif">${esc(p[f.key]||'')}</textarea>`
          : `<input id="gp-${f.key}" value="${esc(p[f.key]||'')}" style="width:100%;background:var(--bg);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:12px;padding:8px;font-family:'DM Sans',sans-serif">`
        }
      </div>
    `).join('')}
    <button onclick="saveGymProfile('${prospectId}')" class="btn btn-primary" style="width:100%;background:var(--green);border-color:var(--green);margin-top:8px">\u2713 Save Profile</button>
  `;

  requestAnimationFrame(() => { panel.style.right = '0'; });
}

function closeGymProfile() {
  const panel = document.getElementById('gym-profile-panel');
  if (panel) {
    panel.style.right = '-420px';
  }
}

function saveGymProfile(prospectId) {
  const p = pipelineData.prospects.find(x => x.id === prospectId);
  if (!p) return;
  ['gymName','ownerName','email','phone','city','state','gymType','notes'].forEach(key => {
    const el = document.getElementById('gp-' + key);
    if (el) p[key] = el.value.trim();
  });
  savePipeline();
  // Also update CRM
  const crmData = JSON.parse(localStorage.getItem('deka_crm')||'{}');
  const crmId = p.gymName.toLowerCase().replace(/[^a-z0-9]/g,'_').slice(0,20);
  crmData[crmId] = Object.assign(crmData[crmId]||{}, {
    contactName: p.ownerName||'', email: p.email||'', phone: p.phone||'',
    city: p.city||'', gymType: p.gymType||'', notes: p.notes||'',
  });
  localStorage.setItem('deka_crm', JSON.stringify(crmData));
  closeGymProfile();
  openOnboardingModal(prospectId);
  showToast('Profile saved');
}

function copySnippet() {
  const text = document.getElementById('affiliate-snippet')?.textContent || '';
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.getElementById('copy-snip-btn');
    if (btn) { btn.textContent = '✓ Copied'; setTimeout(()=>{btn.textContent='📋 Copy';},2000); }
  });
}

// Show onboarding checklist for already-signed prospects from detail panel
function openOnboardingFromDetail(id) {
  const p = pipelineData.prospects.find(x => x.id === id);
  if (!p) return;
  if (!p.onboardingTasks || p.onboardingTasks.length === 0) {
    p.onboardingTasks = JSON.parse(JSON.stringify(DEFAULT_ONBOARDING_TASKS));
    p.onboardingStart = p.onboardingStart || new Date().toISOString().slice(0,10);
    savePipeline();
  }
  openOnboardingModal(id);
}

function copyAgenticCmd() {
  const text = document.getElementById('agentic-cmd')?.textContent || '';
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.getElementById('agentic-copy-btn');
    if (btn) { btn.textContent = '✓ Copied'; setTimeout(()=>{btn.textContent='📋 Copy';},2000); }
  });
}

// ── TOAST ──
let _toastTimer;
function openGmail(url) {
  window.open(url, 'gmail-compose', 'width=960,height=720,menubar=no,toolbar=no,location=yes,resizable=yes');
}

function openEmailInGmail(prospectId) {
  const p = pipelineData.prospects.find(x => x.id === prospectId);
  if (!p || !p.email) { showToast('No email on file for this prospect.'); return; }
  const output = document.getElementById('email-output');
  const body = output ? output.value : '';
  const typeLabel = {cold:'Cold Intro', called:'Called + Email', followup:'Post-Call Follow-up', discovery:'Discovery Recap'};
  const subject = _currentEmailType ? (typeLabel[_currentEmailType] || 'DEKA Affiliate Partnership') + ' — ' + (p.gymName||'') : 'DEKA Affiliate Partnership — ' + (p.gymName||'');
  const url = `https://mail.google.com/mail/?view=cm&to=${encodeURIComponent(p.email)}&su=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  window.open(url, 'gmail-compose', 'width=960,height=720,menubar=no,toolbar=no,location=yes,resizable=yes');
  // Log to CRM
  const today = new Date().toISOString().slice(0,10);
  if (!p.activities) p.activities = [];
  p.activities.unshift({date:today, type:'email', notes:`${typeLabel[_currentEmailType]||'Email'} sent via Gmail`});
  p.lastActivity = today;
  const fu = new Date(); fu.setDate(fu.getDate()+7);
  p.nextAction = 'Follow up';
  p.nextActionDate = fu.toISOString().slice(0,10);
  if (p.stage === 'lead') p.stage = 'contacted';
  savePipeline();
  renderActionQueue();
  showToast('✉ Gmail opened — logged to prospect');
}

function showToast(msg, color) {
  const el = document.getElementById('sync-toast');
  if (!el) return;
  el.textContent = msg;
  el.style.color = color || 'var(--text)';
  el.style.borderColor = color || 'var(--border)';
  el.style.opacity = '1';
  clearTimeout(_toastTimer);
  _toastTimer = setTimeout(() => { el.style.opacity = '0'; }, 3500);
}

// ── HELPERS ──
function esc(v) {
  if (!v) return '';
  return String(v).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ── BOOT ──
init();
</script>

<!-- BULK ACTION BAR -->
<div class="bulk-bar hidden" id="bulk-bar">
  <span class="bulk-count" id="bulk-count">0 selected</span>
  <button class="btn btn-blue" onclick="batchEmail()">&#9993; Send Batch Email &rarr; Contacted</button>
  <button class="btn btn-ghost btn-sm" onclick="clearSelection()">&#10005; Clear</button>
</div>
</body>
</html>
