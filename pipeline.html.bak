function openEventPlannerFromPipeline(gymName) {
  const s = JSON.parse(localStorage.getItem('deka_settings') || '{}');
  let url = s.eventPlannerUrl || 'localhost:5173';
  if (!url.startsWith('http')) url = 'http://' + url;
  if (gymName) url += '?gym=' + encodeURIComponent(gymName);
  window.open(url);
}

function copyEmail() {
  const out = document.getElementById('email-output');
  if (out) navigator.clipboard.writeText(out.value).then(()=>{ const btn=event.target; btn.textContent='✓ Copied'; setTimeout(()=>btn.textContent='📋 Copy',2000); });
}

// ── ADD MODAL ──
function openAddModal() { document.getElementById('add-modal').classList.add('open'); }
function closeAddModal() { document.getElementById('add-modal').classList.remove('open'); }

function saveNewProspect() {
  const get = id => document.getElementById(id)?.value?.trim()||'';
  const gymName = get('new-gymName');
  if (!gymName) { alert('Gym name is required.'); return; }
  const p = {
    id: genId(), gymName, ownerName: get('new-ownerName'), email: get('new-email'),
    phone: get('new-phone'), city: get('new-city'), state: get('new-state').toUpperCase(),
    gymType: get('new-gymType'), stage: get('new-stage')||'lead',
    priority: get('new-priority')||'warm', source: get('new-source')||'',
    estimatedRevenue: get('new-revenue')||'', nextAction: get('new-nextAction'),
    nextActionDate: get('new-nextActionDate'), notes: get('new-notes'),
    lastActivity: new Date().toISOString().slice(0,10),
    activities: [{date: new Date().toISOString().slice(0,10), type:'note', notes:'Prospect added to pipeline.'}],
    createdAt: new Date().toISOString().slice(0,10),
  };
  pipelineData.prospects.push(p);
  savePipeline();
  closeAddModal();
  // Reset form
  ['gymName','ownerName','email','phone','city','state','gymType','revenue','nextAction','nextActionDate','notes'].forEach(f => {
    const el = document.getElementById('new-'+f); if (el) el.value = '';
  });
  populateStateFilter();
  updateHeaderSub();
  showView('board', document.querySelectorAll('.nav-tab')[0]);
}

// ── GOOGLE SHEETS SYNC ──
function syncFromSheet() {
  const config = JSON.parse(localStorage.getItem(GS_CONFIG_KEY)||'{}');
  const url = config.webAppUrl;
  if (!url) {
    showToast('⚠ No sheet connected — configure in Import tab', 'var(--yellow)');
    return;
  }
  showToast('⟳ Syncing Pipeline Tier 1-3...', 'var(--text-dim)');
  const statusEl = document.getElementById('sync-status');
  if (statusEl) statusEl.textContent = 'Syncing...';

  const tabName = 'Pipeline Tier 1-3';
  const scriptUrl = `${url}?tab=${encodeURIComponent(tabName)}&key=${encodeURIComponent(GS_SECRET)}&callback=pipelineSyncCallback`;
  const script = document.createElement('script');
  script.src = scriptUrl;
  script.onerror = () => {
    showToast('✗ Could not reach Google Sheets', 'var(--accent)');
    if (statusEl) statusEl.textContent = '✗ Could not reach Google Sheets.';
  };
  document.head.appendChild(script);
  setTimeout(() => script.remove(), 15000);
}

function pipelineSyncCallback(data) {
  const statusEl = document.getElementById('sync-status');
  try {
    if (!data || (!Array.isArray(data.data) && !Array.isArray(data.values))) throw new Error('No data returned');
    const rows = data.data || data.values;
    if (rows.length < 2) { if (statusEl) statusEl.textContent = 'No rows found in Pipeline tab.'; return; }

    // Find header row
    const header = rows[0].map(h => String(h||'').trim().toLowerCase());
    const col = name => header.findIndex(h => h.includes(name.toLowerCase()));

    const iGym = col('gym name');
    const iLoc = col('location');
    const iState = col('state');
    const iSource = col('source');
    const iManager = col('sales manager');
    const iEmail = col('email');
    const iContact = col('contact name');
    const iPhone = col('mobile');
    const iCallArr = col('call arranged');
    const iCallNeed = col('call to be arranged');
    const iNotes = col('notes');
    const iGymMem = col('gym membership');
    const iDemo = col('demographics');
    const iAffil = col('affiliations');

    let added = 0, updated = 0, skipped = 0;

    for (let i = 1; i < rows.length; i++) {
      const row = rows[i];
      const get = idx => idx >= 0 ? String(row[idx]||'').trim() : '';
      const manager = get(iManager);
      if (!manager.toLowerCase().includes('anthony')) { skipped++; continue; }

      const gymName = get(iGym);
      if (!gymName) { skipped++; continue; }

      // Auto-detect stage
      const callArr = get(iCallArr).toLowerCase();
      const callNeed = get(iCallNeed).toLowerCase();
      let stage = 'lead';
      if (callArr === 'yes' || callArr === 'true' || callArr === '1') stage = 'discovery';
      else if (callNeed && callNeed !== 'no' && callNeed !== '') stage = 'contacted';

      const newFields = {
        gymName, city: get(iLoc), state: get(iState).toUpperCase(),
        source: get(iSource) ? (get(iSource).toLowerCase().includes('referral')?'referral':get(iSource).toLowerCase().includes('social')?'social':get(iSource).toLowerCase().includes('cold')?'cold':'sheet') : 'sheet',
        email: get(iEmail), ownerName: get(iContact), phone: get(iPhone),
        otherAffiliations: get(iAffil), gymMembership: get(iGymMem), demographics: get(iDemo),
      };

      // Merge: find existing by gym name, preserve manual enrichments
      const existIdx = pipelineData.prospects.findIndex(p => {
        return p.gymName.toLowerCase().replace(/[^a-z0-9]/g,' ').trim() ===
               gymName.toLowerCase().replace(/[^a-z0-9]/g,' ').trim();
      });

      if (existIdx >= 0) {
        const exist = pipelineData.prospects[existIdx];
        // Only update sheet-sourced fields; preserve dashboard-enriched fields
        Object.assign(exist, newFields);
        // Only update stage if not already advanced past sheet's auto-detect
        const stageOrder = {lead:0,contacted:1,discovery:2,proposal:3,negotiating:4,signed:5,lost:-1};
        if ((stageOrder[stage]||0) > (stageOrder[exist.stage]||0)) exist.stage = stage;
        updated++;
      } else {
        const notesTxt = get(iNotes);
        pipelineData.prospects.push(Object.assign({}, newFields, {
          id: genId(), stage, priority: 'warm',
          notes: notesTxt, estimatedRevenue: '', nextAction: '', nextActionDate: '',
          lastActivity: new Date().toISOString().slice(0,10),
          activities: [{date:new Date().toISOString().slice(0,10),type:'note',notes:'Imported from Google Sheet.'}],
          createdAt: new Date().toISOString().slice(0,10),
        }));
        added++;
      }
    }

    savePipeline();
    populateStateFilter();
    updateHeaderSub();
    const msg = `✓ Sync done — ${added} added, ${updated} updated`;
    if (statusEl) statusEl.textContent = `${msg}, ${skipped} skipped (other reps)`;
    showToast(msg, 'var(--green)');
    if (currentView === 'board') renderBoard();
    else if (currentView === 'list') renderList();
  } catch(e) {
    showToast('✗ Sync error: ' + e.message, 'var(--accent)');
    if (statusEl) statusEl.textContent = '✗ Sync error: ' + e.message;
  }
}

// ── MANUAL IMPORT ──
// ── FILE UPLOAD (Excel / CSV) ──
let _pendingFileRows = null;

function handleFileDrop(e) {
  e.preventDefault();
  document.getElementById('drop-zone').classList.remove('drag-over');
  const file = e.dataTransfer.files[0];
  if (file) processUploadedFile(file);
}
function handleFileSelect(input) {
  const file = input.files[0];
  if (file) processUploadedFile(file);
  input.value = '';
}
function processUploadedFile(file) {
  const statusEl = document.getElementById('file-status');
  statusEl.textContent = 'Reading file...';
  document.getElementById('file-preview').style.display = 'none';
  const ext = file.name.split('.').pop().toLowerCase();

  const reader = new FileReader();
  reader.onload = function(e) {
    try {
      let rows;
      if (ext === 'csv') {
        rows = parseCSVText(e.target.result);
      } else if (ext === 'xlsx' || ext === 'xls') {
        if (typeof XLSX === 'undefined') { statusEl.textContent = '✗ Excel library not loaded. Try again or use CSV export.'; return; }
        const wb = XLSX.read(e.target.result, {type:'array'});
        const ws = wb.Sheets[wb.SheetNames[0]];
        rows = XLSX.utils.sheet_to_json(ws, {header:1, defval:''});
      } else {
        statusEl.textContent = '✗ Unsupported file type. Use .xlsx, .xls, or .csv.';
        return;
      }
      if (!rows || rows.length < 2) { statusEl.textContent = '✗ File appears empty or has no data rows.'; return; }
      showFilePreview(rows, file.name);
    } catch(err) {
      statusEl.textContent = '✗ Could not read file: ' + err.message;
    }
  };
  if (ext === 'csv') reader.readAsText(file);
  else reader.readAsArrayBuffer(file);
}

function parseCSVText(text) {
  // Handle quoted fields with commas/newlines
  const rows = [];
  const lines = text.replace(/\r\n/g,'\n').replace(/\r/g,'\n');
  let cur = [], field = '', inQ = false;
  for (let i = 0; i < lines.length; i++) {
    const c = lines[i];
    if (inQ) {
      if (c === '"' && lines[i+1] === '"') { field += '"'; i++; }
      else if (c === '"') inQ = false;
      else field += c;
    } else {
      if (c === '"') inQ = true;
      else if (c === ',') { cur.push(field); field = ''; }
      else if (c === '\n') { cur.push(field); rows.push(cur); cur = []; field = ''; }
      else field += c;
    }
  }
  if (field || cur.length) { cur.push(field); rows.push(cur); }
  return rows;
}

// Field definitions for column auto-mapping
const FILE_FIELD_DEFS = [
  {key:'gymName',   label:'Gym / Business Name', aliases:['gym name','business name','company','gym','club name','name']},
  {key:'ownerName', label:'Owner / Contact Name', aliases:['owner','contact name','contact','first name','owner name','point of contact']},
  {key:'email',     label:'Email',                aliases:['email','email address','e-mail']},
  {key:'phone',     label:'Phone',                aliases:['phone','mobile','cell','telephone','contact mobile','phone number']},
  {key:'city',      label:'City / Location',      aliases:['city','location','town','city/state']},
  {key:'state',     label:'State',                aliases:['state','st','province']},
  {key:'gymType',   label:'Gym Type',             aliases:['gym type','type','facility type','membership type','gym membership']},
  {key:'source',    label:'Lead Source',          aliases:['source','lead source','how found','referred by']},
  {key:'notes',     label:'Notes',                aliases:['notes','comments','description','additional notes']},
  {key:'stage',     label:'Stage',                aliases:['stage','status','pipeline stage']},
  {key:'priority',  label:'Priority',             aliases:['priority','urgency','tier']},
];

function autoMapColumns(header) {
  const norm = header.map(h => String(h||'').trim().toLowerCase());
  const mapping = {}; // key → colIndex
  FILE_FIELD_DEFS.forEach(def => {
    for (let i = 0; i < norm.length; i++) {
      if (def.aliases.some(a => norm[i].includes(a) || a.includes(norm[i]))) {
        if (!(def.key in mapping)) mapping[def.key] = i;
        break;
      }
    }
  });
  return mapping;
}

function showFilePreview(rows, fileName) {
  const statusEl = document.getElementById('file-status');
  const previewEl = document.getElementById('file-preview');
  const header = rows[0];
  const dataRows = rows.slice(1).filter(r => r.some(c => String(c||'').trim()));

  _pendingFileRows = rows;

  const mapping = autoMapColumns(header);

  // Build column mapping UI
  const mapWrap = document.getElementById('col-map-rows');
  mapWrap.innerHTML = FILE_FIELD_DEFS.map(def => {
    const colIdx = mapping[def.key] !== undefined ? mapping[def.key] : -1;
    const opts = ['<option value="-1">-- skip --</option>',
      ...header.map((h,i) => `<option value="${i}" ${i===colIdx?'selected':''}>${h||'(col '+(i+1)+')'}</option>`)
    ].join('');
    return `<div class="col-map-row">
      <span style="min-width:150px;color:var(--text-mid)">${def.label}</span>
      <select id="fmap-${def.key}" onchange="refreshPreviewTable()">${opts}</select>
    </div>`;
  }).join('');

  refreshPreviewTable();
  statusEl.textContent = `✓ Loaded "${fileName}" — ${dataRows.length} data rows, ${header.length} columns`;
  previewEl.style.display = 'block';
}

function refreshPreviewTable() {
  if (!_pendingFileRows) return;
  const rows = _pendingFileRows;
  const header = rows[0];
  const dataRows = rows.slice(1).filter(r => r.some(c => String(c||'').trim())).slice(0,5);
  const mapping = getCurrentFileMapping();

  const mappedKeys = Object.keys(mapping).filter(k => mapping[k] >= 0);
  const tableEl = document.getElementById('preview-table-el');
  tableEl.innerHTML = `<thead><tr>${mappedKeys.map(k => `<th>${FILE_FIELD_DEFS.find(d=>d.key===k)?.label||k}</th>`).join('')}</tr></thead>
    <tbody>${dataRows.map(row => `<tr>${mappedKeys.map(k => `<td>${String(row[mapping[k]]||'').substring(0,40)}</td>`).join('')}</tr>`).join('')}</tbody>`;
}

function getCurrentFileMapping() {
  const m = {};
  FILE_FIELD_DEFS.forEach(def => {
    const sel = document.getElementById('fmap-'+def.key);
    if (sel) m[def.key] = parseInt(sel.value);
  });
  return m;
}

function confirmFileImport() {
  if (!_pendingFileRows) return;
  const rows = _pendingFileRows;
  const dataRows = rows.slice(1).filter(r => r.some(c => String(c||'').trim()));
  const mapping = getCurrentFileMapping();
  const statusEl = document.getElementById('file-import-status');

  const get = (row, key) => {
    const idx = mapping[key];
    return idx >= 0 && idx < row.length ? String(row[idx]||'').trim() : '';
  };

  let added = 0, updated = 0, skipped = 0;
  dataRows.forEach(row => {
    const gymName = get(row,'gymName');
    if (!gymName) { skipped++; return; }

    const newFields = {
      gymName, ownerName: get(row,'ownerName'), email: get(row,'email'),
      phone: get(row,'phone'), city: get(row,'city'),
      state: get(row,'state').toUpperCase().substring(0,2),
      gymType: get(row,'gymType'), source: get(row,'source')||'file-import',
      notes: get(row,'notes'),
    };

    // Stage mapping
    const rawStage = get(row,'stage').toLowerCase();
    const stageMap = {lead:'lead',contacted:'contacted',discovery:'discovery',proposal:'proposal',negotiating:'negotiating',signed:'signed',lost:'lost'};
    if (rawStage && stageMap[rawStage]) newFields.stage = stageMap[rawStage];

    // Priority mapping
    const rawPri = get(row,'priority').toLowerCase();
    if (rawPri.includes('hot')) newFields.priority = 'hot';
    else if (rawPri.includes('cold')) newFields.priority = 'cold';
    else if (rawPri.includes('warm')) newFields.priority = 'warm';

    const normName = gymName.toLowerCase().replace(/[^a-z0-9]/g,' ').trim();
    const normEmail = newFields.email.toLowerCase();
    const existIdx = pipelineData.prospects.findIndex(p => {
      const pName = p.gymName.toLowerCase().replace(/[^a-z0-9]/g,' ').trim();
      const pEmail = (p.email||'').toLowerCase();
      return pName === normName || (normEmail && pEmail && pEmail === normEmail);
    });

    if (existIdx >= 0) {
      Object.assign(pipelineData.prospects[existIdx], newFields);
      updated++;
    } else {
      pipelineData.prospects.push(Object.assign({}, newFields, {
        id: genId(), stage: newFields.stage||'lead', priority: newFields.priority||'warm',
        lastActivity: new Date().toISOString().slice(0,10),
        activities: [{date:new Date().toISOString().slice(0,10),type:'note',notes:'Imported from file upload.'}],
        createdAt: new Date().toISOString().slice(0,10),
        estimatedRevenue:'', nextAction:'', nextActionDate:'',
      }));
      added++;
    }
  });

  savePipeline(); populateStateFilter(); updateHeaderSub();
  statusEl.textContent = `✓ Done — ${added} added, ${updated} updated, ${skipped} skipped`;
  _pendingFileRows = null;
  if (currentView === 'board') renderBoard();
  else if (currentView === 'list') renderList();
}

function cancelFileImport() {
  _pendingFileRows = null;
  document.getElementById('file-preview').style.display = 'none';
  document.getElementById('file-status').textContent = '';
}

// ── BROWSE ANY SHEET TAB ──
let _pendingTabRows = null;
let _tabSources = {}; // tabName → sourceLabel

function initSheet2Config() {
  const config = JSON.parse(localStorage.getItem(GS_CONFIG_KEY)||'{}');
  const s1El = document.getElementById('sheet1-status');
  if (s1El) {
    s1El.textContent = config.webAppUrl ? '✓ Connected' : '✗ Not configured — set up in Portfolio Dashboard → Data Manager';
    s1El.style.color = config.webAppUrl ? 'var(--green)' : 'var(--accent)';
  }
  const s2url = config.webAppUrl2 || '';
  const s2El = document.getElementById('gs2-url-input');
  if (s2El) s2El.value = s2url;
  const s2StatusEl = document.getElementById('sheet2-save-status');
  if (s2StatusEl && s2url) { s2StatusEl.textContent = '✓ Saved'; s2StatusEl.style.color = 'var(--green)'; }
}

let _sheet2SaveTimer;
function saveSheet2Url(silent) {
  const url = (document.getElementById('gs2-url-input')?.value||'').trim();
  const config = JSON.parse(localStorage.getItem(GS_CONFIG_KEY)||'{}');
  config.webAppUrl2 = url;
  localStorage.setItem(GS_CONFIG_KEY, JSON.stringify(config));
  const statusEl = document.getElementById('sheet2-save-status');
  if (!statusEl) return;
  if (silent) {
    // Auto-save: debounce the confirmation flash so it doesn't fire on every keystroke
    clearTimeout(_sheet2SaveTimer);
    _sheet2SaveTimer = setTimeout(() => {
      statusEl.textContent = url ? '✓ Auto-saved' : '';
      setTimeout(()=>{statusEl.textContent=''},2000);
    }, 800);
  } else {
    statusEl.textContent = url ? '✓ Saved' : 'Cleared';
    setTimeout(()=>{statusEl.textContent=''},2000);
  }
}

function loadSheetTabs() {
  // Always read live input value first (in case Save wasn't clicked)
  const liveUrl2 = (document.getElementById('gs2-url-input')?.value||'').trim();
  if (liveUrl2) {
    const config = JSON.parse(localStorage.getItem(GS_CONFIG_KEY)||'{}');
    config.webAppUrl2 = liveUrl2;
    localStorage.setItem(GS_CONFIG_KEY, JSON.stringify(config));
  }
  const config = JSON.parse(localStorage.getItem(GS_CONFIG_KEY)||'{}');
  const urls = [
    {url: config.webAppUrl,  label: 'NAM Sheet'},
    {url: config.webAppUrl2, label: 'CRM Sheet'},
  ].filter(s => s.url);

  const statusEl = document.getElementById('tab-list-status');
  if (!urls.length) {
    statusEl.textContent = '✗ No Google Sheets configured. Set up Sheet 1 in Portfolio Dashboard, or paste Sheet 2 URL above.';
    return;
  }
  statusEl.textContent = 'Loading tabs...';
  document.getElementById('tab-picker').style.display = 'none';
  _tabSources = {};

  let pending = urls.length;
  const allTabs = [];
  const sourceResults = [];

  urls.forEach(({url, label}) => {
    const cbName = 'gsTabListCallback_' + Date.now() + '_' + Math.random().toString(36).slice(2);
    const scriptUrl = `${url}?action=list&key=${encodeURIComponent(GS_SECRET)}&callback=${cbName}`;
    let settled = false;
    const settle = (ok, count, error) => {
      if (settled) return; settled = true;
      sourceResults.push({label, ok, count: count||0, error: error||''});
      pending--;
      if (pending === 0) renderTabDropdown(allTabs, statusEl, sourceResults);
    };
    window[cbName] = function(data) {
      delete window[cbName];
      if (data && data.error) {
        settle(false, 0, data.error);
      } else if (data && Array.isArray(data.tabs)) {
        data.tabs.forEach(t => { allTabs.push({name:t, label, url}); _tabSources[t+'__'+label] = {url, label}; });
        settle(true, data.tabs.length);
      } else {
        settle(false, 0, 'no tabs returned');
      }
    };
    const script = document.createElement('script');
    script.src = scriptUrl;
    script.onerror = () => { delete window[cbName]; settle(false, 0, 'network error'); };
    document.head.appendChild(script);
    setTimeout(() => { if (!settled) { if(window[cbName]) delete window[cbName]; settle(false, 0, 'timed out'); } }, 12000);
  });
}

function renderTabDropdown(allTabs, statusEl, sourceResults) {
  if (!allTabs.length) {
    statusEl.textContent = '✗ Could not load tabs. Check both URLs are valid Apps Script Web App URLs.';
    return;
  }
  const sel = document.getElementById('tab-select');
  const byLabel = {};
  allTabs.forEach(t => { if (!byLabel[t.label]) byLabel[t.label] = []; byLabel[t.label].push(t); });
  sel.innerHTML = Object.entries(byLabel).map(([label, tabs]) =>
    `<optgroup label="${label}">${tabs.map(t=>`<option value="${t.name}__${t.label}">${t.name}</option>`).join('')}</optgroup>`
  ).join('');
  document.getElementById('tab-picker').style.display = 'block';

  // Show per-source result summary
  const parts = (sourceResults||[]).map(r =>
    r.ok ? `<span style="color:var(--green)">✓ ${r.label}: ${r.count} tabs</span>`
          : `<span style="color:var(--accent)">✗ ${r.label}: ${r.error}</span>`
  ).join(' &nbsp;·&nbsp; ');
  statusEl.innerHTML = parts || `✓ Found ${allTabs.length} tab(s) across ${Object.keys(byLabel).length} sheet(s)`;
}

function testSheet2() {
  const url = (document.getElementById('gs2-url-input')?.value||'').trim();
  const statusEl = document.getElementById('sheet2-save-status');
  if (!url) { statusEl.textContent = '⚠ Paste a URL first'; statusEl.style.color='var(--yellow)'; return; }
  if (!url.includes('script.google.com')) {
    statusEl.textContent = '✗ That doesn\'t look like a Google Apps Script URL'; statusEl.style.color='var(--accent)'; return;
  }
  statusEl.textContent = 'Testing connection...'; statusEl.style.color='var(--text-dim)';
  const cbName = 'gsTest2_' + Date.now();
  const testUrl = `${url}?action=list&key=${encodeURIComponent(GS_SECRET)}&callback=${cbName}`;
  window[cbName] = function(data) {
    delete window[cbName];
    if (data && data.error) {
      statusEl.textContent = `✗ Script returned: ${data.error}. Check the key or re-deploy.`;
      statusEl.style.color = 'var(--accent)';
    } else if (data && Array.isArray(data.tabs)) {
      statusEl.textContent = `✓ Connected — found ${data.tabs.length} tabs: ${data.tabs.slice(0,4).join(', ')}${data.tabs.length>4?'…':''}`;
      statusEl.style.color = 'var(--green)';
      saveSheet2Url(false);
    } else {
      statusEl.textContent = '✗ Unexpected response — script may not be deployed correctly';
      statusEl.style.color = 'var(--accent)';
    }
  };
  const script = document.createElement('script');
  script.src = testUrl;
  script.onerror = () => {
    delete window[cbName];
    statusEl.textContent = '✗ Could not reach this URL — check it\'s deployed as "Anyone" access';
    statusEl.style.color = 'var(--accent)';
  };
  document.head.appendChild(script);
  setTimeout(() => { if (window[cbName]) { delete window[cbName]; statusEl.textContent='✗ Timed out — try re-deploying the script'; statusEl.style.color='var(--accent)'; } }, 10000);
}

function fetchSelectedTab() {
  const config = JSON.parse(localStorage.getItem(GS_CONFIG_KEY)||'{}');
  const rawVal = document.getElementById('tab-select').value; // "tabName__label"
  const sepIdx = rawVal.lastIndexOf('__');
  const tabName = sepIdx >= 0 ? rawVal.slice(0, sepIdx) : rawVal;
  const label   = sepIdx >= 0 ? rawVal.slice(sepIdx+2) : 'NAM Sheet';
  const src = _tabSources[rawVal] || {url: config.webAppUrl};
  const url = src.url;
  const statusEl = document.getElementById('tab-list-status');
  if (!url || !tabName) return;
  statusEl.textContent = `Loading "${tabName}" from ${label}...`;
  document.getElementById('tab-preview').style.display = 'none';

  const cbName = 'gsTabDataCallback_' + Date.now();
  const scriptUrl = `${url}?tab=${encodeURIComponent(tabName)}&key=${encodeURIComponent(GS_SECRET)}&callback=${cbName}`;
  window[cbName] = function(data) {
    delete window[cbName];
    if (!data || (!Array.isArray(data.data) && !Array.isArray(data.values))) {
      statusEl.textContent = '✗ No data returned from that tab.';
      return;
    }
    const rows = (data.data || data.values).filter(r => r.some(c => String(c||'').trim()));
    if (rows.length < 2) { statusEl.textContent = '✗ Tab appears empty.'; return; }
    _pendingTabRows = rows;
    showTabPreview(rows, tabName);
    statusEl.textContent = `✓ Loaded "${tabName}" — ${rows.length - 1} data rows`;
  };
  const script = document.createElement('script');
  script.src = scriptUrl;
  script.onerror = () => { statusEl.textContent = '✗ Could not load tab data.'; };
  document.head.appendChild(script);
  setTimeout(() => { script.remove(); if (window[cbName]) { delete window[cbName]; statusEl.textContent = '✗ Timed out.'; } }, 15000);
}

function showTabPreview(rows, tabName) {
  const header = rows[0];
  const dataRows = rows.slice(1).slice(0,5);
  const mapping = autoMapColumns(header);

  const mapWrap = document.getElementById('tab-col-map-rows');
  mapWrap.innerHTML = FILE_FIELD_DEFS.map(def => {
    const colIdx = mapping[def.key] !== undefined ? mapping[def.key] : -1;
    const opts = ['<option value="-1">-- skip --</option>',
      ...header.map((h,i) => `<option value="${i}" ${i===colIdx?'selected':''}>${h||'(col '+(i+1)+')'}</option>`)
    ].join('');
    return `<div class="col-map-row">
      <span style="min-width:150px;color:var(--text-mid)">${def.label}</span>
      <select id="tmap-${def.key}" onchange="refreshTabPreviewTable()">${opts}</select>
    </div>`;
  }).join('');

  refreshTabPreviewTable();
  document.getElementById('tab-preview').style.display = 'block';
}

function refreshTabPreviewTable() {
  if (!_pendingTabRows) return;
  const rows = _pendingTabRows;
  const dataRows = rows.slice(1).filter(r => r.some(c => String(c||'').trim())).slice(0,5);
  const mapping = getCurrentTabMapping();
  const mappedKeys = Object.keys(mapping).filter(k => mapping[k] >= 0);
  const tableEl = document.getElementById('tab-preview-table-el');
  tableEl.innerHTML = `<thead><tr>${mappedKeys.map(k => `<th>${FILE_FIELD_DEFS.find(d=>d.key===k)?.label||k}</th>`).join('')}</tr></thead>
    <tbody>${dataRows.map(row => `<tr>${mappedKeys.map(k => `<td>${String(row[mapping[k]]||'').substring(0,40)}</td>`).join('')}</tr>`).join('')}</tbody>`;
}

function getCurrentTabMapping() {
  const m = {};
  FILE_FIELD_DEFS.forEach(def => {
    const sel = document.getElementById('tmap-'+def.key);
    if (sel) m[def.key] = parseInt(sel.value);
  });
  return m;
}

function confirmTabImport() {
  if (!_pendingTabRows) return;
  const rows = _pendingTabRows;
  const dataRows = rows.slice(1).filter(r => r.some(c => String(c||'').trim()));
  const mapping = getCurrentTabMapping();
  const statusEl = document.getElementById('tab-import-status');

  const get = (row, key) => {
    const idx = mapping[key];
    return idx >= 0 && idx < row.length ? String(row[idx]||'').trim() : '';
  };

  let added = 0, updated = 0, skipped = 0, dupes = 0;
  dataRows.forEach(row => {
    const gymName = get(row,'gymName');
    if (!gymName) { skipped++; return; }
    const email = get(row,'email').toLowerCase();

    const newFields = {
      gymName, ownerName: get(row,'ownerName'), email: get(row,'email'),
      phone: get(row,'phone'), city: get(row,'city'),
      state: get(row,'state').toUpperCase().substring(0,2),
      gymType: get(row,'gymType'), source: get(row,'source')||'sheet-import',
      notes: get(row,'notes'),
    };
    const rawStage = get(row,'stage').toLowerCase();
    const stageMap = {lead:'lead',contacted:'contacted',discovery:'discovery',proposal:'proposal',negotiating:'negotiating',signed:'signed',lost:'lost'};
    if (rawStage && stageMap[rawStage]) newFields.stage = stageMap[rawStage];
    const rawPri = get(row,'priority').toLowerCase();
    if (rawPri.includes('hot')) newFields.priority = 'hot';
    else if (rawPri.includes('cold')) newFields.priority = 'cold';
    else if (rawPri.includes('warm')) newFields.priority = 'warm';

    // Dedup: match by gym name OR email
    const normName = gymName.toLowerCase().replace(/[^a-z0-9]/g,' ').trim();
    const existIdx = pipelineData.prospects.findIndex(p => {
      const pName = p.gymName.toLowerCase().replace(/[^a-z0-9]/g,' ').trim();
      const pEmail = (p.email||'').toLowerCase();
      return pName === normName || (email && pEmail && pEmail === email);
    });

    if (existIdx >= 0) {
      // Already exists — update sheet-sourced fields only, preserve manual enrichments
      const exist = pipelineData.prospects[existIdx];
      Object.assign(exist, newFields);
      if (newFields.stage) {
        const stageOrder = {lead:0,contacted:1,discovery:2,proposal:3,negotiating:4,signed:5,lost:-1};
        if ((stageOrder[newFields.stage]||0) > (stageOrder[exist.stage]||0)) exist.stage = newFields.stage;
      }
      updated++; dupes++;
    } else {
      pipelineData.prospects.push(Object.assign({}, newFields, {
        id: genId(), stage: newFields.stage||'lead', priority: newFields.priority||'warm',
        lastActivity: new Date().toISOString().slice(0,10),
        activities: [{date:new Date().toISOString().slice(0,10),type:'note',notes:'Imported from sheet tab.'}],
        createdAt: new Date().toISOString().slice(0,10),
        estimatedRevenue:'', nextAction:'', nextActionDate:'',
      }));
      added++;
    }
  });

  savePipeline(); populateStateFilter(); updateHeaderSub();
  const dupeNote = dupes > 0 ? `, ${dupes} duplicate(s) updated instead of re-added` : '';
  statusEl.textContent = `✓ Done — ${added} new, ${updated} updated, ${skipped} skipped (no name)${dupeNote}`;
  _pendingTabRows = null;
  if (currentView === 'board') renderBoard();
  else if (currentView === 'list') renderList();
}

function cancelTabImport() {
  _pendingTabRows = null;
  document.getElementById('tab-preview').style.display = 'none';
}

function parseManualImport() {
  const raw = document.getElementById('manual-import-text')?.value?.trim();
  if (!raw) return;
  const statusEl = document.getElementById('sync-status');
  try {
    let rows;
    if (raw.startsWith('[')) {
      rows = JSON.parse(raw);
    } else {
      // Parse CSV
      rows = raw.split('\n').map(r => r.split(',').map(c => c.replace(/^"|"$/g,'').trim()));
      const header = rows[0];
      rows = rows.slice(1).map(r => { const o={}; header.forEach((h,i)=>o[h]=r[i]||''); return o; });
    }
    let added = 0;
    rows.forEach(row => {
      const name = row['GYM NAME']||row.gymName||row.name||'';
      if (!name) return;
      if (pipelineData.prospects.find(p=>p.gymName.toLowerCase()===name.toLowerCase())) return;
      pipelineData.prospects.push({
        id:genId(), gymName:name, city:row['LOCATION']||row.city||'',
        state:(row['STATE']||row.state||'').toUpperCase(),
        source:row['SOURCE']||row.source||'sheet', email:row['Email Address']||row.email||'',
        ownerName:row['Contact Name']||row.ownerName||'', phone:row['Contact mobile number']||row.phone||'',
        notes:row['Notes']||row.notes||'', stage:'lead', priority:'warm',
        lastActivity:new Date().toISOString().slice(0,10),
        activities:[{date:new Date().toISOString().slice(0,10),type:'note',notes:'Manually imported.'}],
        createdAt:new Date().toISOString().slice(0,10),
      });
      added++;
    });
    savePipeline(); populateStateFilter(); updateHeaderSub();
    if (statusEl) statusEl.textContent = `✓ Imported ${added} new prospects`;
    if (currentView==='board') renderBoard(); else if (currentView==='list') renderList();
  } catch(e) {
    if (statusEl) statusEl.textContent = '✗ Parse error: ' + e.message;
  }
}

// ── EXPORT ──
function exportPipelineJSON() {
  const blob = new Blob([JSON.stringify(pipelineData, null, 2)], {type:'application/json'});
  const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
  a.download = `deka-pipeline-${new Date().toISOString().slice(0,10)}.json`; a.click();
}

function exportPipelineCSV() {
  const cols = ['gymName','ownerName','email','phone','city','state','gymType','stage','priority','source','estimatedRevenue','nextAction','nextActionDate','lastActivity','notes','createdAt'];
  const hdr = cols.join(',');
  const rows = pipelineData.prospects.map(p => cols.map(c => {
    const v = p[c]==null?'':String(p[c]);
    return v.includes(',')||v.includes('"')||v.includes('\n') ? '"'+v.replace(/"/g,'""')+'"' : v;
  }).join(','));
  const blob = new Blob([[hdr,...rows].join('\n')], {type:'text/csv'});
  const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
  a.download = `deka-pipeline-${new Date().toISOString().slice(0,10)}.csv`; a.click();
}

